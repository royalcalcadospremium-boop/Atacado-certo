{%- comment -%}
  Apple-pure search template.
  - Pill-shaped search input (submits on Enter)
  - Apple-card grid for product results (4 / 2 / 1 responsive)
  - Separate small list for non-product results (pages, articles)
  - Native Shopify pagination
  - Empty state tile + initial state form
{%- endcomment -%}

{%- assign _per_page = section.settings.products_per_page | default: 24 -%}

<section class="ad-search" data-section-id="{{ section.id }}" data-section-type="search-template">

  <header class="ad-search__head">
    <h1 class="ad-search__title ad-display-lg">
      {%- if search.performed and search.terms != blank -%}
        {{ search.terms }}
      {%- else -%}
        Busca
      {%- endif -%}
    </h1>
    {%- if search.performed -%}
      <p class="ad-search__count ad-caption">
        {%- if search.results_count == 1 -%}
          1 resultado
        {%- else -%}
          {{ search.results_count }} resultados
        {%- endif -%}
      </p>
    {%- endif -%}
  </header>

  <form class="ad-search__form" action="{{ routes.search_url }}" method="get" role="search">
    <input type="hidden" name="type" value="product">
    <label class="ad-search__field">
      <span class="ad-search__icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="8" cy="8" r="5.5"></circle>
          <path d="m12.5 12.5 3 3"></path>
        </svg>
      </span>
      <input
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="Buscar produtos…"
        autocomplete="off"
        aria-label="Buscar produtos"
        class="ad-search__input">
      <button type="submit" class="ad-search__submit" aria-label="Buscar">Buscar</button>
    </label>
  </form>

  {%- if search.performed -%}
    {%- if search.results.size == 0 -%}

      <div class="ad-search__empty ad-tile ad-tile--parchment">
        <h2 class="ad-display-lg">Nenhum resultado para &ldquo;{{ search.terms }}&rdquo;</h2>
        <p class="ad-lead">Tente outro termo, ou navegue por nossas coleções.</p>
        {%- render 'apple-button', variant: 'primary', href: '/collections/all', label: 'Ver todos os produtos' -%}
      </div>

    {%- else -%}
      {%- paginate search.results by _per_page -%}

        {%- assign _has_products = false -%}
        {%- for item in search.results -%}
          {%- if item.object_type == 'product' -%}{%- assign _has_products = true -%}{%- break -%}{%- endif -%}
        {%- endfor -%}

        {%- if _has_products -%}
          <div class="ad-search__grid" style="--ad-grid-cols: 4">
            {%- for item in search.results -%}
              {%- if item.object_type == 'product' -%}
                {%- assign _price_str = item.price | money -%}
                {%- if item.compare_at_price > item.price -%}
                  {%- assign _was = item.compare_at_price | money -%}
                {%- else -%}
                  {%- assign _was = blank -%}
                {%- endif -%}
                {%- render 'apple-card',
                    image: item.featured_image,
                    image_alt: item.title,
                    title: item.title,
                    price: _price_str,
                    price_was: _was,
                    href: item.url,
                    action_label: 'Comprar' -%}
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- assign _has_other = false -%}
        {%- for item in search.results -%}
          {%- if item.object_type != 'product' -%}{%- assign _has_other = true -%}{%- break -%}{%- endif -%}
        {%- endfor -%}

        {%- if _has_other -%}
          <section class="ad-search__other">
            <h2 class="ad-search__other-title ad-body-strong">Outras páginas e artigos</h2>
            <ul class="ad-search__other-list">
              {%- for item in search.results -%}
                {%- if item.object_type != 'product' -%}
                  <li class="ad-search__other-item">
                    <a class="ad-search__other-link" href="{{ item.url }}">
                      <span class="ad-body-strong">{{ item.title }}</span>
                      <span class="ad-caption ad-search__other-type">{{ item.object_type }}</span>
                    </a>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </section>
        {%- endif -%}

        {%- if paginate.pages > 1 -%}
          <nav class="ad-search__pagination" role="navigation" aria-label="Paginação">
            {%- if paginate.previous -%}
              <a class="ad-btn ad-btn--text-link" href="{{ paginate.previous.url }}" rel="prev">‹ Anterior</a>
            {%- endif -%}
            <span class="ad-caption" style="opacity:.7">
              Página {{ paginate.current_page }} de {{ paginate.pages }}
            </span>
            {%- if paginate.next -%}
              <a class="ad-btn ad-btn--text-link" href="{{ paginate.next.url }}" rel="next">Próxima ›</a>
            {%- endif -%}
          </nav>
        {%- endif -%}

      {%- endpaginate -%}
    {%- endif -%}

  {%- else -%}

    <div class="ad-search__initial">
      <p class="ad-lead-airy">Digite o nome de um produto para começar — ou explore nossas coleções.</p>
      {%- render 'apple-button', variant: 'secondary-pill', href: '/collections/all', label: 'Navegar por coleções' -%}
    </div>

  {%- endif -%}

</section>

<style>
  .ad-search {
    padding-top: var(--ad-space-xxl);
    padding-bottom: var(--ad-space-section);
  }
  .ad-search > * {
    max-width: 1440px;
    margin-left: auto;
    margin-right: auto;
    padding-left: var(--ad-space-lg);
    padding-right: var(--ad-space-lg);
  }
  .ad-search__head { text-align: center; margin-bottom: var(--ad-space-lg); }
  .ad-search__title { margin: 0 0 var(--ad-space-xs); }
  .ad-search__count { margin: 0; color: var(--ad-color-ink-muted-48); }

  .ad-search__form { max-width: 640px; margin: 0 auto var(--ad-space-xl); }
  .ad-search__field {
    display: flex;
    align-items: center;
    gap: var(--ad-space-xs);
    border: 1px solid var(--ad-color-hairline);
    border-radius: var(--ad-radius-pill);
    background: var(--ad-color-canvas);
    padding: 0 20px;
    height: 44px;
    transition: border-color .2s ease, box-shadow .2s ease;
  }
  .ad-search__field:focus-within {
    border-color: var(--ad-color-ink);
    box-shadow: 0 0 0 3px rgba(0, 102, 204, .12);
  }
  .ad-search__icon {
    display: inline-flex;
    color: var(--ad-color-ink-muted-48);
    flex-shrink: 0;
  }
  .ad-search__input {
    flex: 1;
    border: 0;
    outline: 0;
    background: transparent;
    font: inherit;
    font-family: var(--ad-font-text);
    color: var(--ad-color-ink);
    padding: 12px 4px;
    min-width: 0;
  }
  .ad-search__input::placeholder { color: var(--ad-color-ink-muted-48); }
  .ad-search__submit {
    position: absolute;
    width: 1px; height: 1px;
    margin: -1px; padding: 0; overflow: hidden;
    clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }

  .ad-search__grid {
    display: grid;
    grid-template-columns: repeat(var(--ad-grid-cols, 4), minmax(0, 1fr));
    gap: var(--ad-space-lg);
  }

  .ad-search__other { margin-top: var(--ad-space-xxl); }
  .ad-search__other-title { margin: 0 0 var(--ad-space-md); }
  .ad-search__other-list { list-style: none; margin: 0; padding: 0; }
  .ad-search__other-item { border-top: 1px solid var(--ad-color-hairline); }
  .ad-search__other-item:last-child { border-bottom: 1px solid var(--ad-color-hairline); }
  .ad-search__other-link {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--ad-space-md);
    padding: var(--ad-space-md) 0;
    color: var(--ad-color-ink);
    text-decoration: none;
  }
  .ad-search__other-link:hover { color: var(--ad-color-primary); }
  .ad-search__other-type { color: var(--ad-color-ink-muted-48); text-transform: capitalize; }

  .ad-search__pagination {
    margin-top: var(--ad-space-xxl);
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--ad-space-lg);
  }

  .ad-search__empty {
    text-align: center;
    padding: var(--ad-space-section) var(--ad-space-lg);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--ad-space-md);
    border-radius: var(--ad-radius-lg);
  }
  .ad-search__empty > h2 { margin: 0; }
  .ad-search__empty > p { margin: 0; max-width: 520px; color: var(--ad-color-ink-muted-80); }

  .ad-search__initial {
    text-align: center;
    padding: var(--ad-space-xl) 0 var(--ad-space-section);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--ad-space-md);
  }
  .ad-search__initial > p { margin: 0; max-width: 560px; }

  @media (max-width: 1068px) {
    .ad-search__grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
  @media (max-width: 833px) {
    .ad-search__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 480px) {
    .ad-search__grid { grid-template-columns: 1fr; gap: var(--ad-space-md); }
  }
</style>

{% schema %}
{
  "name": "Busca (Apple)",
  "settings": [
    { "type": "range", "id": "products_per_page", "label": "Produtos por página", "min": 8, "max": 48, "step": 4, "default": 24 }
  ]
}
{% endschema %}
