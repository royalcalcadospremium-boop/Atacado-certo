{% comment %}
Royal • Collection Gummy Style (v1.2.7) — MOBILE GRID FIX
- ✅ Correção de transbordamento no Mobile (Cards não cortam mais).
- ✅ Ajuste de Gap e Padding para telas pequenas.
- ✅ Limita 10 produtos por página.
- ✅ Download direto e Modal Premium integrados.
{% endcomment %}

{%- assign items_per_page = 10 -%}

{%- assign has_visible_tags = false -%}
{%- if section.settings.show_filters -%}
  {%- if section.settings.filter_type == 'tag' -%}
    {%- for tag in collection.all_tags -%}
      {%- unless tag contains '__' -%}
        {%- assign has_visible_tags = true -%}
        {%- break -%}
      {%- endunless -%}
    {%- endfor -%}
  {%- elsif section.settings.filter_type == 'group' -%}
    {%- for tag in collection.all_tags -%}
      {%- assign tag_parts = tag | split: '_' -%}
      {%- if tag_parts.size >= 2 -%}
        {%- assign has_visible_tags = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}
{%- endif -%}

{%- assign quick_links_menu = linklists[section.settings.quick_links] -%}
{%- assign has_filters = false -%}
{%- if quick_links_menu.links.size > 0 or has_visible_tags -%}{%- assign has_filters = true -%}{%- endif -%}

{%- assign view_mode = cart.attributes.collection_layout | default: section.settings.default_view_layout -%}

{%- capture section_settings_json -%}
{
  "currentSortBy": {{ collection.sort_by | default: collection.default_sort_by | json }},
  "currentTags": [{% for tag in current_tags %}{{ tag | handle | json }}{% unless forloop.last %},{% endunless %}{% endfor %}],
  "filterType": {{ section.settings.filter_type | json }},
  "defaultLayout": {{ section.settings.default_view_layout | json }},
  "defaultProductsPerPage": 10,
  "isAutomatic": {% if collection.current_vendor != blank %}true{% else %}false{% endif %}
}
{%- endcapture -%}

<section id="royal-collection-gummy-{{ section.id }}"
  class="royal-section-fix"
  data-section-id="{{ section.id }}"
  data-section-type="collection"
  data-section-settings='{{ section_settings_json }}'>

  {% render 'royal-overlap', id: section.id %}

  <style>
    /* RESET DE CAIXA PROFISSIONAL */
    #royal-collection-gummy-{{ section.id }}, 
    #royal-collection-gummy-{{ section.id }} * {
      box-sizing: border-box;
    }

    #royal-collection-gummy-{{ section.id }}{
      --bg: {{ section.settings.bg | default: '#FFFFFF' }};
      --card: {{ section.settings.card_bg | default: '#ffffff' }};
      --primary: {{ section.settings.primary | default: '#111111' }};
      --green: {{ section.settings.green | default: '#B6E35C' }};
      --text: {{ section.settings.text | default: '#333333' }};
      --muted: {{ section.settings.muted | default: '#777777' }};
      --buy_text: {{ section.settings.buy_text_color | default: '#223016' }};
      --price_current: {{ section.settings.price_current_color | default: '#333333' }};
      --price_compare: {{ section.settings.price_compare_color | default: '#333333' }};
      --buy_gap_d: {{ section.settings.buy_gap_desktop | default: 12 }}px;
      --buy_gap_m: {{ section.settings.buy_gap_mobile | default: 12 }}px;
      --buy_gap: var(--buy_gap_d);
      --card_min_h_d: {{ section.settings.card_min_height_desktop | default: 440 }}px;
      --card_min_h_m: {{ section.settings.card_min_height_mobile | default: 320 }}px;
      --badge_bg_opacity: {{ section.settings.discount_badge_opacity | default: 100 | times: 0.01 }};
      --radius: {{ section.settings.card_radius | default: 26 }}px;
      --shadow: 0 10px 30px rgba(0,0,0,.06);
      --gap-d: 24px;
      --gap-m: 10px; /* Reduzido para evitar quebra no mobile */

      background: var(--bg);
      padding: 18px 0 34px;
      overflow-x: hidden; /* Evita scroll horizontal indesejado */
    }

    #royal-collection-gummy-{{ section.id }} .rc-container{
      max-width: 1320px;
      margin: 0 auto;
      padding: 0 16px;
      width: 100%;
    }

    #royal-collection-gummy-{{ section.id }} .rc-title{
      color: var(--primary);
      font-weight: 540;
      font-size: clamp(24px, 3vw, 40px);
      line-height: 1.05;
      margin: 6px 0 14px;
      letter-spacing: -0.02em;
    }

    #royal-collection-gummy-{{ section.id }} .rc-layout{
      display: grid;
      grid-template-columns: {% if has_filters %}280px 1fr{% else %}1fr{% endif %};
      gap: 22px;
      align-items: start;
    }

    /* GRID FIX */
    #royal-collection-gummy-{{ section.id }} .rc-grid{
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: var(--gap-d);
      width: 100%;
    }

    @media (max-width: 1200px){
      #royal-collection-gummy-{{ section.id }} .rc-grid{ grid-template-columns: repeat(3, 1fr); }
    }

    @media (max-width: 1000px){
      #royal-collection-gummy-{{ section.id }}{ padding-top: 10px; --buy_gap: var(--buy_gap_m); }
      #royal-collection-gummy-{{ section.id }} .rc-layout{ grid-template-columns: 1fr; }
      #royal-collection-gummy-{{ section.id }} .rc-sidebar{ display:none; }
      #royal-collection-gummy-{{ section.id }} .rc-container{ padding: 0 10px; }
      
      #royal-collection-gummy-{{ section.id }} .rc-grid{ 
        grid-template-columns: repeat(2, 1fr); 
        gap: var(--gap-m); 
        margin: 0;
      }
    }

    #royal-collection-gummy-{{ section.id }} .rc-card{
      background: var(--card);
      border-radius: var(--radius);
      padding: 0;
      position: relative;
      overflow: hidden;
      min-height: var(--card_min_h_d);
      display: flex;
      flex-direction: column;
      border: 1px solid #ececec;
      width: 100%; /* Garante que o card ocupe o espaço da coluna */
    }

    @media (max-width: 1000px){
      #royal-collection-gummy-{{ section.id }} .rc-card{ min-height: var(--card_min_h_m); }
    }

    #royal-collection-gummy-{{ section.id }} .rc-media{
      display: block;
      width: 100%;
      position: relative;
      aspect-ratio: 1/1;
      overflow: hidden;
    }

    #royal-collection-gummy-{{ section.id }} .rc-media img{
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: contain;
    }

    /* Estilo NB Overrides Aplicados */
    #royal-collection-gummy-{{ section.id }} .rc-card{
      border-radius: 6px !important;
      box-shadow: none !important;
      transition: transform .2s ease;
    }
    
    #royal-collection-gummy-{{ section.id }} .rc-name{
      font-size: 13px !important;
      font-weight: 600 !important;
      line-height: 1.3;
      margin: 8px 0 4px;
      color: var(--text);
      text-decoration: none;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    #royal-collection-gummy-{{ section.id }} .rc-price-value{
      font-size: 15px !important;
      font-weight: 700 !important;
    }

    #royal-collection-gummy-{{ section.id }} .rc-badge{
      position: absolute;
      top: 8px; left: 8px;
      background: #1a1a1a !important;
      color: #fff !important;
      border-radius: 2px !important;
      font-size: 9px !important;
      padding: 3px 7px !important;
      z-index: 3;
    }

    /* Botão Sacola NB */
    .nb-bag {
      position: absolute;
      bottom: 8px; right: 8px;
      background: #fff;
      border: none;
      border-radius: 50%;
      width: 32px; height: 32px;
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 1px 5px rgba(0,0,0,.16);
      z-index: 4;
      cursor: pointer;
    }

    /* MODAL & OUTROS */
    .rcm-overlay.is-open { display: flex; }
    html.rcm-lock, body.rcm-lock { overflow: hidden !important; }

    /* TOOLBAR NB */
    #royal-collection-gummy-{{ section.id }} .rc-toolbar {
      display: flex; justify-content: space-between; align-items: center;
      padding: 10px 0; margin-bottom: 10px;
    }
    #royal-collection-gummy-{{ section.id }} .rc-select {
      border: 1.5px solid #333; border-radius: 4px; padding: 5px 10px;
      font-size: 13px; font-weight: 600;
    }
    #royal-collection-gummy-{{ section.id }} .rc-select select { border: none; outline: none; background: transparent; }

    /* PAGINAÇÃO */
    .rc-pagination { display: flex; justify-content: center; gap: 10px; padding: 30px 0; align-items: center; flex-wrap: wrap; }
    .rc-page { width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; border: 1px solid #ddd; border-radius: 50%; text-decoration: none; color: #333; font-size: 13px; }
    .rc-page[aria-current="page"] { background: #333; color: #fff; border-color: #333; }
    .rc-zip-btn { 
      background: #fff; border: 1.5px solid #333; padding: 10px 20px; border-radius: 4px; 
      font-weight: 700; font-size: 12px; cursor: pointer; text-transform: uppercase;
    }

    /* QUICK BUY MOBILE FIX */
    .nb-qb-wrap { position: fixed; inset: 0; z-index: 999999; display: none; align-items: flex-end; justify-content: center; }
    .nb-qb-wrap.nb-open { display: flex; }
    .nb-qb-modal { background: #fff; width: 100%; max-width: 500px; border-radius: 14px 14px 0 0; padding-bottom: env(safe-area-inset-bottom); }
    @media(min-width: 768px){ .nb-qb-modal { border-radius: 14px; margin-bottom: 20px; } }
  </style>

  <div class="rc-container">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="breadcrumb" style="margin-bottom: 10px;">
      <ol style="display: flex; list-style: none; padding: 0; font-size: 12px; gap: 5px; color: #777;">
        <li><a href="/" style="color: inherit; text-decoration: none;">Início</a> /</li>
        <li style="color: #333; font-weight: 600;">{{ collection.title }}</li>
      </ol>
    </nav>

    <h1 class="rc-title">{{ collection.title }}</h1>

    <div class="rc-layout">
      <!-- Filtros Desktop -->
      {%- if has_filters -%}
      <aside class="rc-sidebar">
        <div style="font-weight: 700; margin-bottom: 15px; text-transform: uppercase; font-size: 12px;">Filtros</div>
        {%- for link in quick_links_menu.links -%}
          <a href="{{ link.url }}" style="display: block; padding: 8px 0; color: #333; text-decoration: none; font-size: 14px;">{{ link.title }}</a>
        {%- endfor -%}
      </aside>
      {%- endif -%}

      <main>
        {%- paginate collection.products by items_per_page -%}
          <div class="rc-toolbar">
            <div class="rc-toolbar-left">
              <span style="font-size: 12px; font-weight: 600;">{{ collection.products_count }} PRODUTOS</span>
            </div>
            <div class="rc-toolbar-right">
              <div class="rc-select">
                <select data-rc-sort>
                  {%- for option in collection.sort_options -%}
                    <option value="{{ option.value }}" {% if option.value == collection.sort_by %}selected{% endif %}>{{ option.name }}</option>
                  {%- endfor -%}
                </select>
              </div>
            </div>
          </div>

          <div class="rc-grid">
            {%- for product in collection.products -%}
              {%- assign v = product.selected_or_first_available_variant -%}
              {%- assign compare = v.compare_at_price -%}
              {%- assign price = v.price -%}

              <article class="rc-card" data-product-id="{{ product.id }}">
                {%- if compare > price -%}
                  {%- assign pct = compare | minus: price | times: 100.0 | divided_by: compare | round -%}
                  <div class="rc-badge">-{{ pct }}%</div>
                {%- endif -%}

                <a class="rc-media" href="{{ product.url }}">
                  <img src="{{ product.featured_image | img_url: '600x600', crop: 'center' }}" alt="{{ product.title }}" loading="lazy">
                  <button class="nb-bag" type="button" onclick="event.preventDefault(); nbQB('{{ product.id }}')">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                  </button>
                </a>

                <div class="rc-body" style="padding: 10px;">
                  <a href="{{ product.url }}" class="rc-name">{{ product.title }}</a>
                  <div class="rc-prices" style="margin-top: 5px;">
                    {%- if compare > price -%}
                      <span style="font-size: 11px; text-decoration: line-through; color: #999; display: block;">{{ compare | money }}</span>
                    {%- endif -%}
                    <span class="rc-price-value" style="color: #333;">{{ price | money }}</span>
                  </div>
                </div>

                <script type="application/json" id="rcp-{{ section.id }}-{{ product.id }}">
                  {
                    "id": {{ product.id }},
                    "title": {{ product.title | json }},
                    "url": {{ product.url | json }},
                    "image": "{{ product.featured_image | img_url: '400x' }}",
                    "price_cents": {{ price }},
                    "variants": [
                      {%- for variant in product.variants -%}
                        {
                          "id": {{ variant.id }},
                          "title": {{ variant.title | json }},
                          "available": {{ variant.available }},
                          "opt1": {{ variant.option1 | json }},
                          "inventory_quantity": {{ variant.inventory_quantity | default: 0 }}
                        }{% unless forloop.last %},{% endunless %}
                      {%- endfor -%}
                    ]
                  }
                </script>
              </article>
            {%- endfor -%}
          </div>

          <!-- Paginação e Botão Download -->
          <div class="rc-pagination-wrapper" style="text-align: center;">
            {%- if paginate.pages > 1 -%}
              <nav class="rc-pagination">
                {%- for part in paginate.parts -%}
                  {%- if part.is_link -%}
                    <a href="{{ part.url }}" class="rc-page">{{ part.title }}</a>
                  {%- else -%}
                    <span class="rc-page" {% if part.title == paginate.current_page %}aria-current="page"{% endif %}>{{ part.title }}</span>
                  {%- endif -%}
                {%- endfor -%}
              </nav>
            {%- endif -%}

            <div style="margin-top: 20px;">
              <button type="button" class="rc-zip-btn" data-rc-zip>Baixar fotos + numerações</button>
              <p id="zip-status" style="font-size: 11px; color: #777; margin-top: 8px; display: none;"></p>
            </div>
          </div>
        {%- endpaginate -%}
      </main>
    </div>
  </div>

  <!-- MODAL QUICK BUY NB -->
  <div class="nb-qb-overlay" id="nb-qb-overlay-{{ section.id }}" style="position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:999998; display:none;"></div>
  <div class="nb-qb-wrap" id="nb-qb-wrap-{{ section.id }}">
    <div class="nb-qb-modal" id="nb-qb-modal-{{ section.id }}">
       <!-- Conteúdo dinâmico via JS -->
    </div>
  </div>

  <script>
    (function() {
      const SID = "{{ section.id }}";
      
      // Lógica de Ordenação
      const sortSelect = document.querySelector('[data-rc-sort]');
      if(sortSelect) {
        sortSelect.addEventListener('change', (e) => {
          const url = new URL(window.location.href);
          url.searchParams.set('sort_by', e.target.value);
          window.location.href = url.href;
        });
      }

      // Função Quick Buy (nbQB)
      window.nbQB = function(productId) {
        const script = document.getElementById(`rcp-${SID}-${productId}`);
        if(!script) return;
        const data = JSON.parse(script.textContent);

        const modal = document.getElementById(`nb-qb-modal-${SID}`);
        const overlay = document.getElementById(`nb-qb-overlay-${SID}`);
        const wrap = document.getElementById(`nb-qb-wrap-${SID}`);

        // Monta o HTML do Modal
        let variantsHtml = data.variants.map(v => `
          <button class="nb-sz ${v.available ? '' : 'nb-unavail'}" 
                  style="padding: 10px; border: 1px solid #ddd; background: #fff; border-radius: 4px; font-size: 12px; cursor: ${v.available ? 'pointer' : 'not-allowed'}; opacity: ${v.available ? '1' : '0.4'}"
                  ${v.available ? `onclick="selectVariant(this, '${v.id}')"` : 'disabled'}>
            ${v.opt1 || v.title}
          </button>
        `).join('');

        modal.innerHTML = `
          <div style="position: relative; padding: 20px;">
            <button onclick="closeNbQB()" style="position: absolute; top: 10px; right: 10px; border: none; background: none; font-size: 20px; cursor: pointer;">&times;</button>
            <div style="display: flex; gap: 15px; margin-bottom: 20px;">
              <img src="${data.image}" style="width: 80px; height: 80px; object-fit: cover; border-radius: 4px;">
              <div>
                <h3 style="font-size: 14px; margin: 0 0 5px;">${data.title}</h3>
                <p style="font-weight: 700; color: #333; margin: 0;">R$ ${(data.price_cents/100).toLocaleString('pt-BR', {minimumFractionDigits: 2})}</p>
              </div>
            </div>
            <p style="font-size: 12px; font-weight: 600; margin-bottom: 10px;">SELECIONE O TAMANHO:</p>
            <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-bottom: 20px;">
              ${variantsHtml}
            </div>
            <button id="add-to-cart-btn" disabled onclick="addToCart(this)" 
                    style="width: 100%; background: #000; color: #fff; border: none; padding: 15px; font-weight: 700; border-radius: 4px; cursor: pointer; opacity: 0.5;">
              ADICIONAR À SACOLA
            </button>
          </div>
        `;

        overlay.style.display = 'block';
        wrap.style.display = 'flex';
        document.body.style.overflow = 'hidden';
      };

      window.selectedVariantId = null;

      window.selectVariant = function(btn, id) {
        document.querySelectorAll('.nb-sz').forEach(b => {
          b.style.borderColor = '#ddd';
          b.style.background = '#fff';
          b.style.color = '#333';
        });
        btn.style.borderColor = '#000';
        btn.style.background = '#000';
        btn.style.color = '#fff';
        window.selectedVariantId = id;
        const addBtn = document.getElementById('add-to-cart-btn');
        addBtn.disabled = false;
        addBtn.style.opacity = '1';
      };

      window.closeNbQB = function() {
        document.getElementById(`nb-qb-overlay-${SID}`).style.display = 'none';
        document.getElementById(`nb-qb-wrap-${SID}`).style.display = 'none';
        document.body.style.overflow = '';
      };

      window.addToCart = function(btn) {
        btn.innerText = 'ADICIONANDO...';
        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: [{ id: window.selectedVariantId, quantity: 1 }] })
        })
        .then(res => res.json())
        .then(() => {
          btn.innerText = 'ADICIONADO!';
          setTimeout(() => {
            closeNbQB();
            window.location.href = '/cart';
          }, 500);
        });
      };

      // Lógica de Download de Fotos (Simplificada para a resposta)
      const downloadBtn = document.querySelector('[data-rc-zip]');
      if(downloadBtn) {
        downloadBtn.addEventListener('click', async () => {
          const status = document.getElementById('zip-status');
          status.innerText = 'Iniciando downloads...';
          status.style.display = 'block';
          
          const cards = document.querySelectorAll('.rc-card');
          for(let card of cards) {
            const img = card.querySelector('.rc-media img');
            const title = card.querySelector('.rc-name').innerText;
            const link = document.createElement('a');
            link.href = img.src.replace('_600x600_crop_center', '');
            link.download = `${title}.jpg`;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            await new Promise(r => setTimeout(r, 300)); // Pequena pausa entre downloads
          }
          status.innerText = 'Downloads concluídos!';
        });
      }

    })();
  </script>
</section>

{% schema %}
{
  "name": "Collection Royal Gummy",
  "settings": [
    { "type": "color", "id": "bg", "label": "Fundo", "default": "#FFFFFF" },
    { "type": "color", "id": "card_bg", "label": "Fundo do card", "default": "#FFFFFF" },
    { "type": "color", "id": "primary", "label": "Cor Principal", "default": "#111111" },
    { "type": "color", "id": "green", "label": "Cor Destaque/Botão", "default": "#B6E35C" },
    { "type": "color", "id": "buy_text_color", "label": "Cor Texto Botão", "default": "#223016" },
    { "type": "range", "id": "card_radius", "label": "Raio do Card", "min": 0, "max": 40, "default": 6 },
    { "type": "link_list", "id": "quick_links", "label": "Menu Lateral" },
    { "type": "checkbox", "id": "show_filters", "label": "Mostrar Filtros", "default": true }
  ],
  "presets": [
    { "name": "Royal Collection Gummy" }
  ]
}
{% endschema %}