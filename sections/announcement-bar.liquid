{%- comment -%}
  Apple-pure announcement bar (Subsistema 1, v4).
  v4: 3 CTAs (Atacado/Dropshipping/Varejo) sempre renderizam com fallbacks
  hardcoded apontando pras LPs. Settings sobrescrevem. Opt-out via checkbox.
{%- endcomment -%}

{%- if section.settings.show_announcement -%}
  {%- assign m1_text  = section.settings.modality_1_text  | default: 'ATACADO · 10+ pares' -%}
  {%- assign m1_url   = section.settings.modality_1_url   | default: '/pages/atacado' -%}
  {%- assign m1_emoji = section.settings.modality_1_emoji | default: '🏠' -%}
  {%- assign m2_text  = section.settings.modality_2_text  | default: 'DROPSHIPPING · qualquer quantidade' -%}
  {%- assign m2_url   = section.settings.modality_2_url   | default: '/pages/dropshipping' -%}
  {%- assign m2_emoji = section.settings.modality_2_emoji | default: '📦' -%}
  {%- assign m3_text  = section.settings.modality_3_text  | default: 'VAREJO · frete grátis R$150+' -%}
  {%- assign m3_url   = section.settings.modality_3_url   | default: '/pages/varejo' -%}
  {%- assign m3_emoji = section.settings.modality_3_emoji | default: '🛒' -%}
  {%- assign show_modalities = true -%}
  {%- if section.settings.force_legacy_text -%}{%- assign show_modalities = false -%}{%- endif -%}

<section class="ad-announcement" data-section-id="{{ section.id }}" data-section-type="announcement-bar" role="region" aria-label="Aviso da loja">
  <div class="ad-announcement__inner">
    {%- if show_modalities -%}
      <nav class="ad-announcement__modalities" aria-label="Modalidades de compra">
        <a class="ad-announcement__cta-modality ad-caption" href="{{ m1_url }}">
          {%- if m1_emoji != blank -%}<span class="ad-announcement__cta-emoji" aria-hidden="true">{{ m1_emoji }}</span>{%- endif -%}
          <span class="ad-announcement__cta-label">{{ m1_text }}</span>
        </a>
        <span class="ad-announcement__sep" aria-hidden="true">·</span>
        <a class="ad-announcement__cta-modality ad-caption" href="{{ m2_url }}">
          {%- if m2_emoji != blank -%}<span class="ad-announcement__cta-emoji" aria-hidden="true">{{ m2_emoji }}</span>{%- endif -%}
          <span class="ad-announcement__cta-label">{{ m2_text }}</span>
        </a>
        <span class="ad-announcement__sep" aria-hidden="true">·</span>
        <a class="ad-announcement__cta-modality ad-caption" href="{{ m3_url }}">
          {%- if m3_emoji != blank -%}<span class="ad-announcement__cta-emoji" aria-hidden="true">{{ m3_emoji }}</span>{%- endif -%}
          <span class="ad-announcement__cta-label">{{ m3_text }}</span>
        </a>
      </nav>
    {%- else -%}
      {%- if section.settings.text != blank -%}
        <p class="ad-announcement__text ad-caption">{{ section.settings.text }}</p>
      {%- endif -%}
      {%- if section.settings.cta_text != blank and section.settings.cta_url != blank -%}
        <a class="ad-announcement__cta ad-caption-strong" href="{{ section.settings.cta_url }}">
          {{ section.settings.cta_text }}
          <span aria-hidden="true">&rsaquo;</span>
        </a>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{%- assign bg_color = section.settings.background_color | default: '#f5f5f7' -%}
{%- assign bg_gradient_enabled = section.settings.bg_gradient_enabled -%}
{%- assign bg_grad_1 = section.settings.background_color_1 | default: '#3498db' -%}
{%- assign bg_grad_2 = section.settings.background_color_2 | default: '#040404' -%}
{%- assign bg_grad_dir = section.settings.gradient_direction | default: 'vertical' -%}
{%- assign text_color_setting = section.settings.text_color | default: '#1d1d1f' -%}
{%- case bg_grad_dir -%}
  {%- when 'vertical' -%}{%- assign grad_css = 'to bottom' -%}
  {%- when 'vertical-up' -%}{%- assign grad_css = 'to top' -%}
  {%- when 'horizontal' -%}{%- assign grad_css = 'to right' -%}
  {%- when 'horizontal-rev' -%}{%- assign grad_css = 'to left' -%}
  {%- when 'diagonal' -%}{%- assign grad_css = '135deg' -%}
  {%- else -%}{%- assign grad_css = 'to bottom' -%}
{%- endcase -%}

<style>
  #shopify-section-{{ section.id }} .ad-announcement {
    {%- if bg_gradient_enabled -%}
    background: linear-gradient({{ grad_css }}, {{ bg_grad_1 }}, {{ bg_grad_2 }});
    {%- else -%}
    background-color: {{ bg_color }};
    {%- endif -%}
    color: {{ text_color_setting }};
    border-bottom: var(--ad-border-soft);
  }
  #shopify-section-{{ section.id }} .ad-announcement__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--ad-space-md);
    padding: 8px var(--ad-space-lg);
    min-height: 32px;
    max-width: 1440px;
    margin: 0 auto;
    text-align: center;
  }
  #shopify-section-{{ section.id }} .ad-announcement__text {
    margin: 0;
    color: {{ text_color_setting }};
    opacity: 0.92;
  }
  #shopify-section-{{ section.id }} .ad-announcement__cta {
    color: {{ text_color_setting }};
    text-decoration: none;
    white-space: nowrap;
  }
  #shopify-section-{{ section.id }} .ad-announcement__cta:hover {
    text-decoration: underline;
  }
  #shopify-section-{{ section.id }} .ad-announcement__modalities {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--ad-space-sm);
    font-family: var(--ad-font-text);
  }
  #shopify-section-{{ section.id }} .ad-announcement__cta-modality {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: {{ text_color_setting }};
    font-weight: 400;
    text-decoration: none;
    white-space: nowrap;
    padding: 2px 6px;
    border-radius: 4px;
    transition: opacity 160ms ease;
  }
  #shopify-section-{{ section.id }} .ad-announcement__cta-modality:hover,
  #shopify-section-{{ section.id }} .ad-announcement__cta-modality:focus-visible {
    text-decoration: underline;
    text-underline-offset: 3px;
    opacity: 0.85;
  }
  #shopify-section-{{ section.id }} .ad-announcement__cta-emoji {
    font-size: 0.95em;
    line-height: 1;
  }
  #shopify-section-{{ section.id }} .ad-announcement__sep {
    color: {{ text_color_setting }};
    user-select: none;
    opacity: 0.45;
  }
  @media (max-width: 640px) {
    #shopify-section-{{ section.id }} .ad-announcement__inner {
      padding: 6px var(--ad-space-md);
      gap: var(--ad-space-xs);
      flex-wrap: wrap;
    }
    #shopify-section-{{ section.id }} .ad-announcement__modalities {
      gap: 4px;
      font-size: 12px;
      letter-spacing: -0.12px;
      line-height: 1.0;
    }
    #shopify-section-{{ section.id }} .ad-announcement__cta-modality {
      padding: 2px 4px;
    }
  }
</style>
{%- endif -%}

{% schema %}
{
  "name": "Barra de anúncio (Apple)",
  "settings": [
    { "type": "checkbox", "id": "show_announcement", "label": "Mostrar barra", "default": true },
    { "type": "checkbox", "id": "force_legacy_text", "label": "Forçar texto único (em vez dos 3 CTAs)", "default": false, "info": "Marque para esconder os 3 CTAs e mostrar apenas o texto abaixo." },

    { "type": "header", "content": "Cores" },
    { "type": "color", "id": "background_color", "label": "Fundo (sólido)", "default": "#f5f5f7" },
    { "type": "color", "id": "text_color", "label": "Cor do texto e dos CTAs", "default": "#1d1d1f" },

    { "type": "header", "content": "Fundo em degradê (opcional)" },
    { "type": "checkbox", "id": "bg_gradient_enabled", "label": "Ativar degradê", "default": false, "info": "Quando ativo, substitui a cor sólida acima." },
    { "type": "color", "id": "background_color_1", "label": "Cor 1 (início)", "default": "#3498db" },
    { "type": "color", "id": "background_color_2", "label": "Cor 2 (fim)", "default": "#040404" },
    { "type": "select", "id": "gradient_direction", "label": "Direção do degradê", "default": "vertical", "options": [
      { "value": "vertical", "label": "↓ Vertical (cima → baixo)" },
      { "value": "vertical-up", "label": "↑ Vertical (baixo → cima)" },
      { "value": "horizontal", "label": "→ Horizontal (esq → dir)" },
      { "value": "horizontal-rev", "label": "← Horizontal (dir → esq)" },
      { "value": "diagonal", "label": "↘ Diagonal" }
    ] },
    { "type": "header", "content": "Modo legado (texto único)" },
    { "type": "paragraph", "content": "Visível apenas se o checkbox acima estiver marcado." },
    { "type": "text", "id": "text", "label": "Texto", "default": "Atacado · Dropshipping · Varejo — direto da fábrica" },
    { "type": "text", "id": "cta_text", "label": "Texto do link (opcional)" },
    { "type": "url", "id": "cta_url", "label": "URL do link (opcional)" },

    { "type": "header", "content": "Modo modalidades (3 CTAs)" },
    { "type": "paragraph", "content": "Preencha os 3 grupos abaixo para exibir os botões de modalidade no lugar do texto único." },

    { "type": "header", "content": "Modalidade 1 — Atacado" },
    { "type": "text", "id": "modality_1_emoji", "label": "Emoji / ícone", "default": "🏠" },
    { "type": "text", "id": "modality_1_text", "label": "Texto", "default": "ATACADO · 10+ pares" },
    { "type": "url", "id": "modality_1_url", "label": "URL" },

    { "type": "header", "content": "Modalidade 2 — Dropshipping" },
    { "type": "text", "id": "modality_2_emoji", "label": "Emoji / ícone", "default": "📦" },
    { "type": "text", "id": "modality_2_text", "label": "Texto", "default": "DROPSHIPPING · qualquer quantidade" },
    { "type": "url", "id": "modality_2_url", "label": "URL" },

    { "type": "header", "content": "Modalidade 3 — Varejo" },
    { "type": "text", "id": "modality_3_emoji", "label": "Emoji / ícone", "default": "🛒" },
    { "type": "text", "id": "modality_3_text", "label": "Texto", "default": "VAREJO · frete grátis R$150+" },
    { "type": "url", "id": "modality_3_url", "label": "URL" }
  ]
}
{% endschema %}
