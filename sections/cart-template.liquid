{%- comment -%}
  Apple-pure cart page (Subsistema 5).
  Two-column: line items list left, sticky summary right.
{%- endcomment -%}

<section class="ad-cart" data-section-id="{{ section.id }}" data-section-type="cart-template">

  {%- if cart.item_count == 0 -%}
    <div class="ad-cart__empty">
      <h1 class="ad-display-lg">Sua sacola está vazia.</h1>
      <p class="ad-lead">Comece explorando o catálogo.</p>
      {%- render 'apple-button', variant: 'primary', href: '/collections/all', label: 'Ver produtos' -%}
    </div>
  {%- else -%}

    <header class="ad-cart__head">
      <h1 class="ad-cart__title ad-display-lg">Sua sacola</h1>
      <p class="ad-cart__count ad-caption">
        {%- if cart.item_count == 1 -%}1 item{%- else -%}{{ cart.item_count }} itens{%- endif -%}
      </p>
    </header>

    <form action="{{ routes.cart_url }}" method="post" novalidate class="ad-cart__form" data-cart-form>

      <div class="ad-cart__inner">

        <ul class="ad-cart__items" role="list">
          {%- for item in cart.items -%}
            <li class="ad-cart__item" data-cart-item data-line-key="{{ item.key }}">
              <a class="ad-cart__media" href="{{ item.url }}">
                {%- if item.image -%}
                  <img src="{{ item | img_url: '240x' }}" alt="{{ item.product.title | escape }}" width="120" height="120" loading="lazy">
                {%- endif -%}
              </a>
              <div class="ad-cart__text">
                <a class="ad-cart__name ad-body-strong" href="{{ item.url }}">{{ item.product.title }}</a>
                {%- if item.product.has_only_default_variant == false -%}
                  <p class="ad-cart__variant ad-caption">{{ item.variant.title }}</p>
                {%- endif -%}
                {%- if item.product.vendor != blank -%}
                  <p class="ad-cart__vendor ad-caption">{{ item.product.vendor }}</p>
                {%- endif -%}
              </div>
              <div class="ad-cart__qty">
                <label class="ad-caption" for="qty-{{ item.key }}">Qtd</label>
                <input id="qty-{{ item.key }}" type="number" name="updates[{{ item.key }}]" value="{{ item.quantity }}" min="0" class="ad-cart__qty-input" data-line-qty data-line-key="{{ item.key }}">
              </div>
              <div class="ad-cart__price">
                <p class="ad-body" data-line-price>{{ item.final_line_price | money }}</p>
                {%- if item.original_line_price > item.final_line_price -%}
                  <p class="ad-caption ad-cart__price-was"><s>{{ item.original_line_price | money }}</s></p>
                {%- endif -%}
              </div>
              <a class="ad-cart__remove ad-btn ad-btn--text-link" href="{{ routes.cart_change_url }}?line={{ forloop.index }}&amp;quantity=0" aria-label="Remover {{ item.product.title | escape }}">Remover</a>
            </li>
          {%- endfor -%}
        </ul>

        <aside class="ad-cart__summary">
          <div class="ad-cart__summary-inner">
            <h2 class="ad-cart__summary-title ad-tagline">Resumo do pedido</h2>

            <dl class="ad-cart__totals">
              <dt class="ad-body">Subtotal</dt>
              <dd class="ad-display-md" data-cart-subtotal>{{ cart.items_subtotal_price | money }}</dd>
            </dl>

            {%- if cart.cart_level_discount_applications.size > 0 -%}
              {%- for discount in cart.cart_level_discount_applications -%}
                <dl class="ad-cart__discount">
                  <dt class="ad-caption">Desconto: {{ discount.title }}</dt>
                  <dd class="ad-body" style="color: var(--ad-color-primary)">- {{ discount.total_allocated_amount | money }}</dd>
                </dl>
              {%- endfor -%}
            {%- endif -%}

            <p class="ad-fine-print ad-cart__shipping-note">
              Frete e impostos calculados no checkout.
            </p>

            <div class="ad-cart__actions">
              <button type="submit" name="checkout" class="ad-btn ad-btn--primary ad-btn--store-hero ad-cart__checkout">
                Finalizar Compra
              </button>
              <a class="ad-btn ad-btn--text-link ad-cart__continue" href="/collections/all">Continuar Comprando</a>
              {%- if section.settings.whatsapp_url != blank -%}
                {%- render 'apple-button',
                    variant: 'secondary-pill',
                    href: section.settings.whatsapp_url,
                    label: 'Falar no WhatsApp' -%}
              {%- endif -%}
            </div>

            <p class="ad-micro-legal ad-cart__legal">
              {{ section.settings.legal_note | default: 'Pagamento via Mercado Pago. Pix, boleto e cartão de crédito.' }}
            </p>
          </div>
        </aside>

      </div>

      {%- if cart.note != blank -%}
        <textarea name="note" hidden>{{ cart.note }}</textarea>
      {%- endif -%}

    </form>

  {%- endif -%}

</section>

<style>
  .ad-cart {
    padding: var(--ad-space-xxl) 0 var(--ad-space-section);
    background: var(--ad-color-canvas);
  }
  .ad-cart > * {
    max-width: 1440px;
    margin-left: auto;
    margin-right: auto;
    padding-left: var(--ad-space-lg);
    padding-right: var(--ad-space-lg);
  }

  .ad-cart__empty {
    text-align: center;
    padding: var(--ad-space-section) 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--ad-space-md);
  }
  .ad-cart__empty h1 { margin: 0; }
  .ad-cart__empty p { margin: 0; color: var(--ad-color-ink-muted-80); }

  .ad-cart__head { margin-bottom: var(--ad-space-xl); }
  .ad-cart__title { margin: 0 0 var(--ad-space-xxs); }
  .ad-cart__count { margin: 0; color: var(--ad-color-ink-muted-48); }

  .ad-cart__inner {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: var(--ad-space-xxl);
    align-items: start;
  }

  .ad-cart__items {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--ad-color-divider-soft);
  }
  .ad-cart__item {
    display: grid;
    grid-template-columns: 120px 1fr auto auto auto;
    gap: var(--ad-space-md);
    align-items: center;
    padding: var(--ad-space-lg) 0;
    border-bottom: 1px solid var(--ad-color-divider-soft);
  }
  .ad-cart__media {
    width: 120px; height: 120px;
    background: var(--ad-color-canvas-parchment);
    border-radius: var(--ad-radius-md);
    overflow: hidden;
    display: block;
  }
  .ad-cart__media img { width: 100%; height: 100%; object-fit: contain; }
  .ad-cart__text { display: flex; flex-direction: column; gap: 2px; }
  .ad-cart__name { color: var(--ad-color-ink); text-decoration: none; }
  .ad-cart__name:hover { text-decoration: underline; }
  .ad-cart__variant, .ad-cart__vendor { margin: 0; color: var(--ad-color-ink-muted-48); }
  .ad-cart__qty { display: flex; flex-direction: column; gap: 4px; }
  .ad-cart__qty label { color: var(--ad-color-ink-muted-48); }
  .ad-cart__qty-input {
    width: 64px;
    padding: 6px 10px;
    border: 1px solid var(--ad-color-hairline);
    border-radius: var(--ad-radius-sm);
    font-size: var(--ad-type-body-size);
    text-align: center;
  }
  .ad-cart__price { display: flex; flex-direction: column; align-items: flex-end; gap: 2px; }
  .ad-cart__price p { margin: 0; }
  .ad-cart__price-was { color: var(--ad-color-ink-muted-48); }
  .ad-cart__remove { white-space: nowrap; }

  .ad-cart__summary { position: sticky; top: 120px; }
  .ad-cart__summary-inner {
    background: var(--ad-color-canvas-parchment);
    border-radius: var(--ad-radius-lg);
    padding: var(--ad-space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--ad-space-md);
  }
  .ad-cart__summary-title { margin: 0; }
  .ad-cart__totals, .ad-cart__discount {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin: 0;
    gap: var(--ad-space-md);
  }
  .ad-cart__totals dt, .ad-cart__discount dt { margin: 0; color: var(--ad-color-ink-muted-80); }
  .ad-cart__totals dd, .ad-cart__discount dd { margin: 0; color: var(--ad-color-ink); }
  .ad-cart__shipping-note { margin: 0; color: var(--ad-color-ink-muted-48); }
  .ad-cart__actions { display: flex; flex-direction: column; gap: var(--ad-space-sm); margin-top: var(--ad-space-sm); }
  .ad-cart__actions .ad-btn { width: 100%; }
  .ad-cart__legal { margin: 0; color: var(--ad-color-ink-muted-48); text-align: center; }

  @media (max-width: 1068px) {
    .ad-cart__inner { grid-template-columns: 1fr; }
    .ad-cart__summary { position: static; }
  }
  @media (max-width: 640px) {
    .ad-cart__item {
      grid-template-columns: 80px 1fr;
      grid-template-areas:
        "media text"
        "media price"
        "qty   remove";
      gap: var(--ad-space-sm);
    }
    .ad-cart__media { width: 80px; height: 80px; grid-area: media; }
    .ad-cart__text { grid-area: text; }
    .ad-cart__qty { grid-area: qty; flex-direction: row; align-items: center; gap: var(--ad-space-xs); }
    .ad-cart__price { grid-area: price; align-items: flex-end; }
    .ad-cart__remove { grid-area: remove; justify-self: end; }
  }
</style>

<script>
(function(){
  var root = document.querySelector('[data-section-id="{{ section.id }}"]');
  if (!root) return;

  // Debounced auto-update on quantity change
  var inputs = root.querySelectorAll('[data-line-qty]');
  var debounceTimer;

  inputs.forEach(function(input){
    input.addEventListener('change', function(){
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(function(){
        updateCart(input.dataset.lineKey, parseInt(input.value, 10) || 0);
      }, 350);
    });
  });

  function updateCart(key, quantity) {
    fetch('{{ routes.cart_change_url }}.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ id: key, quantity: quantity })
    })
    .then(function(r){ return r.json(); })
    .then(function(cart){
      if (quantity === 0) {
        window.location.reload();
        return;
      }
      var subtotalEl = root.querySelector('[data-cart-subtotal]');
      if (subtotalEl) {
        subtotalEl.textContent = formatMoney(cart.items_subtotal_price);
      }
      // update line price
      var line = cart.items.find(function(i){ return i.key === key; });
      if (line) {
        var lineEl = root.querySelector('[data-line-key="' + key + '"]');
        var priceEl = lineEl && lineEl.querySelector('[data-line-price]');
        if (priceEl) priceEl.textContent = formatMoney(line.final_line_price);
      }
    })
    .catch(function(){ window.location.reload(); });
  }

  function formatMoney(cents) {
    var n = (cents / 100).toFixed(2).replace('.', ',');
    var parts = n.split(',');
    parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, '.');
    return 'R$ ' + parts.join(',');
  }
})();
</script>

{% schema %}
{
  "name": "Carrinho (Apple)",
  "settings": [
    { "type": "url", "id": "whatsapp_url", "label": "URL WhatsApp", "default": "https://wa.me/5562991902661" },
    { "type": "richtext", "id": "legal_note", "label": "Nota legal (abaixo do CTA)", "default": "<p>Pagamento via Mercado Pago. Pix, boleto e cartão de crédito.</p>" }
  ]
}
{% endschema %}
