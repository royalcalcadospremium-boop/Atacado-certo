{%- comment -%}
  Apple-pure header (Subsistema 1).
  Two-tier nav: 44px black global-nav + 52px frosted-parchment sub-nav.
  Mobile collapses to hamburger + centered logo + bag.
{%- endcomment -%}

{%- assign navigation_menu_handle = section.settings.navigation_menu | default: 'main-menu' -%}
{%- assign navigation_menu = linklists[navigation_menu_handle] -%}

<header class="ad-header" data-section-id="{{ section.id }}" data-section-type="header" role="banner">

  {%- comment -%} ────────── GLOBAL NAV (44px black) ────────── {%- endcomment -%}
  <nav class="ad-global-nav" aria-label="Navegação principal">
    <div class="ad-global-nav__inner">

      <button class="ad-global-nav__hamburger" type="button" aria-expanded="false" aria-controls="ad-mobile-drawer" aria-label="Abrir menu">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" aria-hidden="true">
          <path d="M1 4h14M1 8h14M1 12h14"/>
        </svg>
      </button>

      <a class="ad-global-nav__logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | img_url: '200x' }}" alt="{{ shop.name | escape }}" width="100" height="20" loading="eager" decoding="async">
        {%- else -%}
          <span class="ad-nav-link">{{ shop.name }}</span>
        {%- endif -%}
      </a>

      <ul class="ad-global-nav__links">
        {%- for link in navigation_menu.links limit: 8 -%}
          <li><a class="ad-nav-link" href="{{ link.url }}">{{ link.title }}</a></li>
        {%- endfor -%}
      </ul>

      <div class="ad-global-nav__utils">
        <a class="ad-global-nav__icon" href="{{ routes.search_url }}" aria-label="Buscar">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <circle cx="8" cy="8" r="5.5"/><path d="m12 12 4 4"/>
          </svg>
        </a>
        <a class="ad-global-nav__icon" href="{{ routes.account_url }}" aria-label="Minha conta">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <circle cx="9" cy="6" r="3"/><path d="M3 16c0-3 2.7-5 6-5s6 2 6 5"/>
          </svg>
        </a>
        <a class="ad-global-nav__icon ad-global-nav__bag" href="{{ routes.cart_url }}" aria-label="Carrinho com {{ cart.item_count }} itens">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M3 6h12l-1 9H4z"/><path d="M6 6V4a3 3 0 0 1 6 0v2"/>
          </svg>
          {%- if cart.item_count > 0 -%}
            <span class="ad-global-nav__bag-count" aria-hidden="true">{{ cart.item_count }}</span>
          {%- endif -%}
        </a>
      </div>

    </div>
  </nav>

  {%- comment -%} ────────── SUB-NAV (52px frosted parchment) ────────── {%- endcomment -%}
  <nav class="ad-sub-nav ad-frosted" aria-label="Sub-navegação">
    <div class="ad-sub-nav__inner">
      <a class="ad-sub-nav__category ad-tagline" href="{{ routes.root_url }}">
        {{- section.settings.brand_tagline | default: 'Royal Atacado' -}}
      </a>
      <ul class="ad-sub-nav__links">
        {%- for block in section.blocks -%}
          {%- if block.type == 'sub_link' -%}
            <li><a class="ad-button-utility" href="{{ block.settings.url }}">{{ block.settings.label }}</a></li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
      {%- if section.settings.cta_text != blank and section.settings.cta_url != blank -%}
        {%- render 'apple-button',
            variant: 'primary',
            href: section.settings.cta_url,
            label: section.settings.cta_text -%}
      {%- endif -%}
    </div>
  </nav>

  {%- comment -%} ────────── MOBILE DRAWER ────────── {%- endcomment -%}
  <aside id="ad-mobile-drawer" class="ad-mobile-drawer" hidden aria-modal="true" role="dialog" aria-label="Menu de navegação">
    <div class="ad-mobile-drawer__head">
      <a class="ad-mobile-drawer__logo" href="{{ routes.root_url }}">
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | img_url: '200x' }}" alt="{{ shop.name | escape }}" width="100" height="20">
        {%- else -%}
          <span class="ad-tagline">{{ shop.name }}</span>
        {%- endif -%}
      </a>
      <button class="ad-mobile-drawer__close" type="button" aria-label="Fechar menu">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
          <path d="M3 3l12 12M15 3L3 15"/>
        </svg>
      </button>
    </div>
    <ul class="ad-mobile-drawer__links">
      {%- for link in navigation_menu.links -%}
        <li><a class="ad-mobile-drawer__link ad-display-md" href="{{ link.url }}">{{ link.title }}</a></li>
      {%- endfor -%}
    </ul>
    <div class="ad-mobile-drawer__foot">
      <a class="ad-button-utility" href="{{ routes.account_url }}">Minha conta</a>
      <a class="ad-button-utility" href="{{ routes.search_url }}">Buscar</a>
      <a class="ad-button-utility" href="{{ routes.cart_url }}">Carrinho ({{ cart.item_count }})</a>
    </div>
  </aside>

</header>

<style>
  /* ── Global nav (44px black bar) ─────────────────────────────── */
  .ad-header { isolation: isolate; }
  .ad-global-nav {
    background-color: var(--ad-color-surface-black);
    color: var(--ad-color-on-dark);
    height: 44px;
    position: sticky; top: 0; z-index: 100;
  }
  .ad-global-nav__inner {
    display: flex;
    align-items: center;
    gap: var(--ad-space-md);
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 var(--ad-space-lg);
    height: 100%;
  }
  .ad-global-nav__hamburger {
    display: none;
    background: none; border: 0; color: inherit;
    padding: 8px; cursor: pointer;
    width: 32px; height: 32px;
    align-items: center; justify-content: center;
  }
  .ad-global-nav__logo {
    color: inherit; text-decoration: none;
    display: inline-flex; align-items: center;
  }
  .ad-global-nav__logo img {
    display: block; height: 20px; width: auto;
  }
  .ad-global-nav__links {
    list-style: none; margin: 0; padding: 0;
    display: flex; gap: var(--ad-space-xl);
    flex: 1; justify-content: center;
  }
  .ad-global-nav__links .ad-nav-link {
    color: inherit; text-decoration: none; opacity: 0.85;
    transition: opacity 120ms ease-out;
  }
  .ad-global-nav__links .ad-nav-link:hover,
  .ad-global-nav__links .ad-nav-link:focus-visible { opacity: 1; }
  .ad-global-nav__utils {
    display: flex; gap: var(--ad-space-md); align-items: center;
  }
  .ad-global-nav__icon {
    color: inherit; opacity: 0.85;
    display: inline-flex; align-items: center; justify-content: center;
    padding: 8px; min-width: 32px; min-height: 32px;
    position: relative; text-decoration: none;
    transition: opacity 120ms ease-out;
  }
  .ad-global-nav__icon:hover { opacity: 1; }
  .ad-global-nav__bag-count {
    position: absolute; top: 2px; right: 0;
    background: var(--ad-color-primary);
    color: var(--ad-color-on-primary);
    font-size: 9px; font-weight: 600;
    min-width: 16px; height: 16px; border-radius: 9999px;
    display: inline-flex; align-items: center; justify-content: center;
    padding: 0 4px; line-height: 1;
  }

  /* ── Sub-nav (52px frosted parchment) ─────────────────────────── */
  .ad-sub-nav {
    height: 52px;
    position: sticky; top: 44px; z-index: 99;
    color: var(--ad-color-ink);
  }
  .ad-sub-nav__inner {
    display: flex;
    align-items: center;
    gap: var(--ad-space-xl);
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 var(--ad-space-lg);
    height: 100%;
  }
  .ad-sub-nav__category {
    color: inherit; text-decoration: none;
  }
  .ad-sub-nav__links {
    list-style: none; margin: 0; padding: 0;
    display: flex; gap: var(--ad-space-lg);
    flex: 1;
  }
  .ad-sub-nav__links a {
    color: var(--ad-color-ink-muted-80);
    text-decoration: none;
  }
  .ad-sub-nav__links a:hover,
  .ad-sub-nav__links a:focus-visible {
    color: var(--ad-color-ink);
  }

  /* ── Mobile drawer ───────────────────────────────────────────── */
  .ad-mobile-drawer {
    position: fixed; inset: 0; z-index: 200;
    background-color: var(--ad-color-surface-tile-1);
    color: var(--ad-color-on-dark);
    padding: var(--ad-space-xl);
    overflow-y: auto;
    animation: ad-fade-in 220ms ease-out;
  }
  .ad-mobile-drawer[hidden] { display: none; }
  @keyframes ad-fade-in { from { opacity: 0; } to { opacity: 1; } }

  .ad-mobile-drawer__head {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: var(--ad-space-xxl);
  }
  .ad-mobile-drawer__logo { color: inherit; text-decoration: none; }
  .ad-mobile-drawer__logo img { display: block; height: 20px; }
  .ad-mobile-drawer__close {
    background: none; border: 0; color: inherit;
    padding: 8px; cursor: pointer;
    width: 32px; height: 32px;
    display: inline-flex; align-items: center; justify-content: center;
  }
  .ad-mobile-drawer__links {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-direction: column; gap: var(--ad-space-md);
  }
  .ad-mobile-drawer__link {
    color: inherit; text-decoration: none;
    display: block; padding: var(--ad-space-xs) 0;
  }
  .ad-mobile-drawer__foot {
    display: flex; flex-wrap: wrap;
    gap: var(--ad-space-sm);
    margin-top: var(--ad-space-xxl);
    padding-top: var(--ad-space-lg);
    border-top: 1px solid rgba(255,255,255,0.12);
  }

  /* ── Responsive ──────────────────────────────────────────────── */
  @media (max-width: 833px) {
    .ad-global-nav__hamburger { display: inline-flex; }
    .ad-global-nav__links { display: none; }
    .ad-global-nav__logo { flex: 1; justify-content: center; }
    .ad-sub-nav__links { display: none; }
    .ad-sub-nav__inner { gap: var(--ad-space-md); }
  }
</style>

<script>
(function () {
  var hamburger = document.querySelector('.ad-global-nav__hamburger');
  var drawer = document.getElementById('ad-mobile-drawer');
  if (!hamburger || !drawer) return;
  var closer = drawer.querySelector('.ad-mobile-drawer__close');

  function openDrawer() {
    drawer.hidden = false;
    hamburger.setAttribute('aria-expanded', 'true');
    document.documentElement.style.overflow = 'hidden';
  }
  function closeDrawer() {
    drawer.hidden = true;
    hamburger.setAttribute('aria-expanded', 'false');
    document.documentElement.style.overflow = '';
  }

  hamburger.addEventListener('click', openDrawer);
  if (closer) closer.addEventListener('click', closeDrawer);
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && !drawer.hidden) closeDrawer();
  });
  drawer.addEventListener('click', function (e) {
    if (e.target.closest('a')) closeDrawer();
  });
})();
</script>

{% schema %}
{
  "name": "Cabeçalho (Apple)",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo (PNG branco, altura ~20px)" },
    { "type": "link_list", "id": "navigation_menu", "label": "Menu principal (até 8 itens)", "default": "main-menu" },
    { "type": "text", "id": "brand_tagline", "label": "Tagline da sub-nav", "default": "Royal Atacado" },
    { "type": "header", "content": "Sub-nav · botão primário" },
    { "type": "text", "id": "cta_text", "label": "Texto do botão", "default": "Falar no WhatsApp" },
    { "type": "url", "id": "cta_url", "label": "URL do botão" }
  ],
  "blocks": [
    {
      "type": "sub_link",
      "name": "Link da sub-nav",
      "settings": [
        { "type": "text", "id": "label", "label": "Texto", "default": "Atacado" },
        { "type": "url", "id": "url", "label": "URL" }
      ]
    }
  ],
  "max_blocks": 5
}
{% endschema %}
