{%- assign selected_variant = product.selected_or_first_available_variant -%}

<style>
  /* ====== BASE ====== */
  .product-info-refactored {
    max-width: 100%;
    background: white;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  }

  .product-info-refactored * {
    box-sizing: border-box;
  }

  .product-container {
    max-width: 100%;
    margin: 0 auto;
    background: white;
    display: flex;
    flex-direction: column;
  }

  /* ====== PRODUCT INFO BLOCK ====== */
  .product-info-block {
    padding: 8px 16px 0;
  }

  /* ====== TITLE ====== */
  .product-title {
    font-size: 22px;
    font-weight: 700;
    color: #111111;
    line-height: 1.3;
    margin: 0 0 10px;
    word-wrap: break-word;
    letter-spacing: -0.2px;
  }

  /* ====== RATINGS ====== */
  .product-ratings {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    margin-bottom: 10px;
  }

  .product-ratings .stars {
    color: #F5A623;
    display: flex;
    gap: 1px;
    font-size: 16px;
    letter-spacing: -1px;
  }

  .product-ratings .rating-link {
    color: #F5A623;
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
  }

  .product-ratings .rating-link:hover {
    text-decoration: underline;
  }

  /* ====== SKU ====== */
  .product-sku {
    font-size: 13px;
    color: #888888;
    margin-bottom: 14px;
  }

  /* ====== PRICE ====== */
  .price-section {
    margin-bottom: 18px;
  }

  .price-row {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .product-price {
    font-size: 32px;
    font-weight: 700;
    color: #111111;
    line-height: 1;
  }

  .price-compare {
    font-size: 15px;
    color: #BBBBBB;
    text-decoration: line-through;
    font-weight: 400;
    margin-top: 3px;
  }

  .discount-badge {
    background: #D42B2B;
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    padding: 2px 7px;
    border-radius: 4px;
    line-height: 1.5;
  }

  /* ====== SECTION LABEL ====== */
  .section-label {
    font-size: 14px;
    color: #222222;
    margin-bottom: 10px;
    font-weight: 400;
    display: block;
  }

  .section-label .selected-option-value {
    font-weight: 500;
  }

  /* ====== COLOR SWATCHES ====== */
  .color-section {
    margin-bottom: 16px;
  }

  .color-grid {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 8px;
    margin-bottom: 4px;
  }

  .color-item {
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .color-item input[type="radio"] {
    display: none;
  }

  .color-thumbnail-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .color-thumbnail {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 2px;
    border: 1px solid #e5e5e5;
    display: block;
  }

  .color-underline {
    display: block;
    height: 3px;
    width: 100%;
    background: transparent;
    margin-top: 3px;
    border-radius: 1px;
    transition: background 0.2s;
  }

  .color-item.is-selected .color-underline,
  .color-item:has(input:checked) .color-underline {
    background: #D42B2B;
  }

  /* ====== SIZE SELECTOR ====== */
  .size-section {
    margin-bottom: 18px;
  }

  .size-rows {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .size-grid {
    display: grid;
    gap: 8px;
  }

  .size-grid-row-1 {
    grid-template-columns: repeat(6, 1fr);
  }

  .size-grid-row-2 {
    grid-template-columns: repeat(5, 1fr);
  }

  .size-button {
    height: 48px;
    border: 1px solid #CCCCCC;
    border-radius: 3px;
    background: white;
    font-size: 15px;
    font-weight: 400;
    color: #111111;
    cursor: pointer;
    transition: all 0.15s;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }

  .size-button:hover {
    border-color: #888888;
  }

  .size-button.active {
    border: 2px solid #D42B2B;
    font-weight: 600;
  }

  .size-button.unavailable {
    opacity: 0.3;
    cursor: not-allowed;
    pointer-events: none;
  }

  /* ====== BUY BUTTONS ====== */
  .button-section {
    display: flex;
    gap: 8px;
    margin-bottom: 14px;
    align-items: stretch;
  }

  .btn-buy {
    flex: 1;
    height: 52px;
    background: #D42B2B;
    color: white;
    border: none;
    border-radius: 3px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    letter-spacing: 0.2px;
  }

  .btn-buy:hover {
    background: #B91F1F;
  }

  .btn-buy:active {
    transform: scale(0.98);
  }

  .btn-cart {
    position: relative;
    width: 52px;
    height: 52px;
    flex-shrink: 0;
    border: 1px solid #CCCCCC;
    border-radius: 3px;
    background: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    color: #111111;
  }

  .btn-cart:hover {
    border-color: #888888;
  }

  .cart-plus-badge {
    position: absolute;
    top: -7px;
    right: -7px;
    width: 18px;
    height: 18px;
    background: #111111;
    color: white;
    border-radius: 50%;
    font-size: 13px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    border: 1.5px solid white;
  }

  /* ====== FEATURES (Provador / Medidas) ====== */
  .features-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin-bottom: 14px;
  }

  .feature-btn {
    height: 44px;
    border: 1px solid #CCCCCC;
    border-radius: 3px;
    background: white;
    font-size: 13px;
    color: #333333;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    transition: border-color 0.2s;
    font-weight: 400;
  }

  .feature-btn:hover {
    border-color: #888888;
  }

  .feature-icon {
    width: 15px;
    height: 15px;
    flex-shrink: 0;
  }

  /* ====== WISHLIST ====== */
  .wishlist-section {
    padding: 12px 0;
    border-bottom: 1px solid #EEEEEE;
    margin-bottom: 16px;
  }

  .wishlist-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 14px;
    color: #111111;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0;
    transition: color 0.2s;
  }

  .wishlist-btn:hover .wishlist-text {
    color: #D42B2B;
  }

  .wishlist-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    color: #111111;
  }

  .wishlist-text {
    text-decoration: underline;
    color: #111111;
    font-size: 14px;
    transition: color 0.2s;
  }

  /* ====== SHIPPING ====== */
  .shipping-section {
    margin-bottom: 16px;
  }

  .shipping-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 14px;
    font-weight: 500;
    color: #111111;
    margin-bottom: 10px;
  }

  .shipping-help {
    color: #1A6EC7;
    cursor: pointer;
    text-decoration: none;
    font-size: 13px;
    font-weight: 400;
    display: flex;
    align-items: center;
    gap: 3px;
  }

  .shipping-help:hover {
    text-decoration: underline;
  }

  .shipping-help svg {
    flex-shrink: 0;
  }

  .shipping-form {
    display: flex;
    gap: 8px;
  }

  .shipping-input {
    flex: 0 1 50%;
    height: 48px;
    border: 1px solid #CCCCCC;
    border-radius: 3px;
    padding: 0 14px;
    font-size: 15px;
    color: #111111;
    outline: none;
  }

  .shipping-input::placeholder {
    color: #BBBBBB;
  }

  .shipping-input:focus {
    border-color: #888888;
  }

  .shipping-btn {
    flex: 1;
    height: 48px;
    background: #D42B2B;
    color: white;
    border: none;
    border-radius: 3px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
    letter-spacing: 0.2px;
  }

  .shipping-btn:hover {
    background: #B91F1F;
  }

  /* ====== ACCORDION ====== */
  .accordion-section {
    border-top: 1px solid #EEEEEE;
  }

  .accordion-item {
    border-bottom: 1px solid #EEEEEE;
  }

  .accordion-header {
    height: 58px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: white;
    border: none;
    cursor: pointer;
    padding: 0;
    width: 100%;
    font-size: 15px;
    font-weight: 500;
    color: #111111;
    transition: background 0.15s;
  }

  .accordion-header:hover {
    background: #FAFAFA;
  }

  .accordion-toggle {
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #111111;
    font-size: 22px;
    font-weight: 300;
    flex-shrink: 0;
  }

  .accordion-content {
    display: none;
    padding: 4px 0 18px;
    color: #555555;
    font-size: 14px;
    line-height: 1.65;
  }

  .accordion-content.open {
    display: block;
  }

  /* ====== FLOATING BUTTON ====== */
  .floating-buy-btn {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 56px;
    background: #D42B2B;
    color: white;
    border: none;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    z-index: 9999;
    width: 100%;
    letter-spacing: 0.2px;
  }

  .floating-buy-btn.visible {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ====== RESPONSIVE ====== */
  @media (max-width: 640px) {
    .product-info-block {
      padding: 16px 16px 0;
    }

    .product-title {
      font-size: 19px;
    }

    .product-price {
      font-size: 28px;
    }

    .color-grid {
      gap: 6px;
    }

    .size-grid-row-1 {
      grid-template-columns: repeat(6, 1fr);
    }

    .size-grid-row-2 {
      grid-template-columns: repeat(5, 1fr);
    }
  }

  @media (min-width: 768px) {
    .floating-buy-btn {
      display: none !important;
    }
  }
</style>

<div class="product-info-refactored">
  <div class="product-container">
    <div class="product-info-block">

      <!-- TITLE -->
      <h1 class="product-title">{{ product.title }}</h1>

      <!-- RATINGS -->
      <div class="product-ratings">
        <span class="stars">
          <span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span>
        </span>
        <a href="#reviews" class="rating-link" data-review-count>(5) Clique e veja!</a>
      </div>

      <!-- PRICE -->
      <div class="price-section">
        {%- if selected_variant.compare_at_price > selected_variant.price -%}
          {%- assign discount_pct = selected_variant.compare_at_price | minus: selected_variant.price | times: 100 | divided_by: selected_variant.compare_at_price | round -%}
          <div class="price-row">
            <div class="product-price" data-product-price>{{ selected_variant.price | money_without_trailing_zeros }}</div>
            <span class="discount-badge">-{{ discount_pct }}%</span>
          </div>
          <div class="price-compare">{{ selected_variant.compare_at_price | money_without_trailing_zeros }}</div>
        {%- else -%}
          <div class="product-price" data-product-price>{{ selected_variant.price | money_without_trailing_zeros }}</div>
        {%- endif -%}
      </div>

      {%- form 'product', product, class: 'product-form' -%}

        <!-- VARIANTE COM IMAGEM: Cor + qualquer opção não-tamanho -->
        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            {%- assign opt_lower = option.name | downcase -%}
            {%- comment -%} Detecta se é opção de tamanho/numeração {%- endcomment -%}
            {%- assign first_val = option.values.first | strip -%}
            {%- assign first_num = first_val | plus: 0 -%}
            {%- assign is_size_opt = false -%}
            {%- if opt_lower contains 'tamanho' or opt_lower contains 'size' or opt_lower contains 'numeraç' -%}
              {%- assign is_size_opt = true -%}
            {%- elsif first_num > 0 -%}
              {%- assign is_size_opt = true -%}
            {%- elsif first_val == 'P' or first_val == 'M' or first_val == 'G' or first_val == 'GG' or first_val == 'PP' or first_val == 'EG' or first_val == 'XG' or first_val == 'p' or first_val == 'm' or first_val == 'g' or first_val == 'gg' -%}
              {%- assign is_size_opt = true -%}
            {%- endif -%}
            {%- unless is_size_opt -%}
              {%- if opt_lower == 'cor' or opt_lower == 'color' or opt_lower == 'colour' or opt_lower == 'cores' -%}
              <div class="color-section">
                <span class="section-label">Cor: <span class="selected-option-value" id="selected-color-{{ forloop.index }}">{{ option.selected_value }}</span></span>
                <div class="color-grid">
                  {%- for value in option.values -%}
                    {%- comment -%}Find first variant with this color to get variant image{%- endcomment -%}
                    {%- assign color_swatch_img = nil -%}
                    {%- for variant in product.variants -%}
                      {%- if option.position == 1 and variant.option1 == value -%}
                        {%- assign color_swatch_img = variant.featured_media -%}
                        {%- break -%}
                      {%- elsif option.position == 2 and variant.option2 == value -%}
                        {%- assign color_swatch_img = variant.featured_media -%}
                        {%- break -%}
                      {%- elsif option.position == 3 and variant.option3 == value -%}
                        {%- assign color_swatch_img = variant.featured_media -%}
                        {%- break -%}
                      {%- endif -%}
                    {%- endfor -%}

                    {%- if color_swatch_img -%}
                      {%- assign swatch_url = color_swatch_img | img_url: '100x' -%}
                    {%- else -%}
                      {%- assign swatch_url = product.featured_image | img_url: '100x' -%}
                    {%- endif -%}

                    <label class="color-item {% if value == option.selected_value %}is-selected{% endif %}"
                           data-color-label-id="selected-color-{{ forloop.parentloop.index }}">
                      <input
                        type="radio"
                        name="option{{ option.position }}"
                        value="{{ value | escape }}"
                        {% if value == option.selected_value %}checked{% endif %}
                        class="color-radio"
                        data-color-value="{{ value | escape }}"
                        data-color-label-id="selected-color-{{ forloop.parentloop.index }}"
                      >
                      <span class="color-thumbnail-wrapper">
                        <img
                          class="color-thumbnail"
                          src="{{ swatch_url }}"
                          alt="{{ value | escape }}"
                          loading="lazy"
                          width="52"
                          height="52"
                        >
                        <span class="color-underline"></span>
                      </span>
                    </label>
                  {%- endfor -%}
                </div>
              </div>
              {%- else -%}
                {%- comment -%} Opção não-tamanho e não-cor: exibe com imagem da variante {%- endcomment -%}
                <div class="color-section">
                  <span class="section-label">{{ option.name }}: <span class="selected-option-value" id="selected-opt-{{ forloop.index }}">{{ option.selected_value }}</span></span>
                  <div class="color-grid">
                    {%- for value in option.values -%}
                      {%- assign opt_swatch_img = nil -%}
                      {%- for variant in product.variants -%}
                        {%- if option.position == 1 and variant.option1 == value -%}
                          {%- assign opt_swatch_img = variant.featured_media -%}
                          {%- break -%}
                        {%- elsif option.position == 2 and variant.option2 == value -%}
                          {%- assign opt_swatch_img = variant.featured_media -%}
                          {%- break -%}
                        {%- elsif option.position == 3 and variant.option3 == value -%}
                          {%- assign opt_swatch_img = variant.featured_media -%}
                          {%- break -%}
                        {%- endif -%}
                      {%- endfor -%}
                      {%- if opt_swatch_img -%}
                        {%- assign opt_url = opt_swatch_img | img_url: '100x' -%}
                      {%- else -%}
                        {%- assign opt_url = product.featured_image | img_url: '100x' -%}
                      {%- endif -%}
                      <label class="color-item {% if value == option.selected_value %}is-selected{% endif %}"
                             data-color-label-id="selected-opt-{{ forloop.parentloop.index }}">
                        <input type="radio" name="option{{ option.position }}" value="{{ value | escape }}"
                               {% if value == option.selected_value %}checked{% endif %}
                               class="color-radio" data-color-value="{{ value | escape }}"
                               data-color-label-id="selected-opt-{{ forloop.parentloop.index }}">
                        <span class="color-thumbnail-wrapper">
                          <img class="color-thumbnail" src="{{ opt_url }}" alt="{{ value | escape }}" loading="lazy" width="52" height="52">
                          <span class="color-underline"></span>
                        </span>
                      </label>
                    {%- endfor -%}
                  </div>
                </div>
              {%- endif -%}
            {%- endunless -%}
          {%- endfor -%}
        {%- endunless -%}

        <!-- SIZE / OPTION SELECTOR (apenas tamanho/numeração) -->
        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            {%- assign opt_lower = option.name | downcase -%}
            {%- assign first_val = option.values.first | strip -%}
            {%- assign first_num = first_val | plus: 0 -%}
            {%- assign is_color_opt = false -%}
            {%- if opt_lower == 'cor' or opt_lower == 'color' or opt_lower == 'colour' or opt_lower == 'cores' -%}
              {%- assign is_color_opt = true -%}
            {%- endif -%}
            {%- assign is_size_opt = false -%}
            {%- if opt_lower contains 'tamanho' or opt_lower contains 'size' or opt_lower contains 'numeraç' -%}
              {%- assign is_size_opt = true -%}
            {%- elsif first_num > 0 -%}
              {%- assign is_size_opt = true -%}
            {%- elsif first_val == 'P' or first_val == 'M' or first_val == 'G' or first_val == 'GG' or first_val == 'PP' or first_val == 'EG' or first_val == 'XG' or first_val == 'p' or first_val == 'm' or first_val == 'g' or first_val == 'gg' -%}
              {%- assign is_size_opt = true -%}
            {%- endif -%}
            {%- if is_size_opt and is_color_opt == false -%}
              <div class="size-section" data-size-option-position="{{ option.position }}">
                <div class="size-rows">
                  <div class="size-grid size-grid-row-1">
                    {%- for value in option.values -%}
                      {%- if forloop.index <= 6 -%}
                        {%- comment -%}Verifica disponibilidade do tamanho{%- endcomment -%}
                        {%- assign size_avail = false -%}
                        {%- for variant in product.variants -%}
                          {%- if option.position == 1 and variant.option1 == value and variant.available -%}
                            {%- assign size_avail = true -%}
                            {%- break -%}
                          {%- elsif option.position == 2 and variant.option2 == value and variant.available -%}
                            {%- assign size_avail = true -%}
                            {%- break -%}
                          {%- elsif option.position == 3 and variant.option3 == value and variant.available -%}
                            {%- assign size_avail = true -%}
                            {%- break -%}
                          {%- endif -%}
                        {%- endfor -%}
                        <button
                          type="button"
                          class="size-button {% if value == option.selected_value %}active{% endif %} {% unless size_avail %}unavailable{% endunless %}"
                          data-size="{{ value | escape }}"
                          data-option-position="{{ option.position }}"
                          {% unless size_avail %}disabled aria-disabled="true"{% endunless %}
                        >{{ value }}</button>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                  {%- if option.values.size > 6 -%}
                    <div class="size-grid size-grid-row-2">
                      {%- for value in option.values -%}
                        {%- if forloop.index > 6 -%}
                          {%- assign size_avail = false -%}
                          {%- for variant in product.variants -%}
                            {%- if option.position == 1 and variant.option1 == value and variant.available -%}
                              {%- assign size_avail = true -%}
                              {%- break -%}
                            {%- elsif option.position == 2 and variant.option2 == value and variant.available -%}
                              {%- assign size_avail = true -%}
                              {%- break -%}
                            {%- elsif option.position == 3 and variant.option3 == value and variant.available -%}
                              {%- assign size_avail = true -%}
                              {%- break -%}
                            {%- endif -%}
                          {%- endfor -%}
                          <button
                            type="button"
                            class="size-button {% if value == option.selected_value %}active{% endif %} {% unless size_avail %}unavailable{% endunless %}"
                            data-size="{{ value | escape }}"
                            data-option-position="{{ option.position }}"
                            {% unless size_avail %}disabled aria-disabled="true"{% endunless %}
                          >{{ value }}</button>
                        {%- endif -%}
                      {%- endfor -%}
                    </div>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        {%- endunless -%}

        <input type="hidden" name="id" value="{{ selected_variant.id }}" class="product-variant-id">

        <!-- BUY BUTTON -->
        <div class="button-section">
          <button type="submit" class="btn-buy" name="add">Comprar Agora</button>
        </div>

      {%- endform -%}

      <!-- MODALITY SELECTOR -->
      <div class="pinfo-modality">
        <p class="pinfo-modality__label">Como você quer comprar?</p>
        <div class="pinfo-modality__tabs" role="tablist">
          <button class="pinfo-modality__tab pinfo-modality__tab--active" role="tab" data-tab="atacado" aria-selected="true">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            Atacado
          </button>
          <button class="pinfo-modality__tab" role="tab" data-tab="drop" aria-selected="false">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            Dropshipping
          </button>
          <button class="pinfo-modality__tab" role="tab" data-tab="varejo" aria-selected="false">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            Varejo
          </button>
        </div>
        <div class="pinfo-modality__panels">
          <div class="pinfo-modality__panel pinfo-modality__panel--active" id="tab-atacado" role="tabpanel">
            <strong>Mínimo 10 pares</strong> — melhor preço por par para revenda. Misture modelos, cores e numerações no mesmo pedido. Pix ou boleto.
          </div>
          <div class="pinfo-modality__panel" id="tab-drop" role="tabpanel" hidden>
            <strong>Qualquer quantidade</strong> — você vende, nós despachamos direto para seu cliente. Sem estoque mínimo. Perfeito para dropshippers e afiliados.
          </div>
          <div class="pinfo-modality__panel" id="tab-varejo" role="tabpanel" hidden>
            <strong>Compra unitária</strong> — frete grátis acima de R$150. Entregamos em até 5 dias úteis com rastreio em tempo real.
          </div>
        </div>
        <a href="/collections/all" class="pinfo-modality__cta">Ver todos os produtos</a>
      </div>

      <!-- BAIXAR PARA REVENDA -->
      <div class="pinfo-download">
        <a href="/collections/{{ product.type | handleize | default: 'all' }}" class="pinfo-download__btn">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Baixar fotos para revenda
        </a>
        <p class="pinfo-download__hint">Fotos com tabela de numeração prontas para WhatsApp e redes sociais</p>
      </div>

      <!-- ACCORDIONS -->
      <div class="accordion-section">
        <div class="accordion-item">
          <button type="button" class="accordion-header" data-accordion-btn>
            <span>Descrição do Produto</span>
            <span class="accordion-toggle">+</span>
          </button>
          <div class="accordion-content">
            {{ product.description | strip_html | truncatewords: 80 }}
          </div>
        </div>

        <div class="accordion-item">
          <button type="button" class="accordion-header" data-accordion-btn>
            <span>Especificações Técnicas</span>
            <span class="accordion-toggle">+</span>
          </button>
          <div class="accordion-content">
            <strong>Marca:</strong> {{ product.vendor }}<br>
            <strong>SKU:</strong> {{ selected_variant.sku | default: product.id }}<br>
            {%- if selected_variant.weight > 0 -%}
              <strong>Peso:</strong> {{ selected_variant.weight }} {{ shop.weight_unit }}<br>
            {%- endif -%}
            <strong>Disponibilidade:</strong> {% if selected_variant.available %}Em estoque{% else %}Esgotado{% endif %}
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- STICKY FLOATING BUY BUTTON (Mobile) -->
<button class="floating-buy-btn visible" id="floating-buy-btn">Comprar Agora</button>

<script>
(function() {
  // ---- Accordion ----
  document.querySelectorAll('[data-accordion-btn]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var content = this.nextElementSibling;
      var toggle = this.querySelector('.accordion-toggle');
      var isOpen = content.classList.contains('open');
      content.classList.toggle('open');
      toggle.textContent = isOpen ? '+' : '−';
    });
  });

  // ---- Color swatch selection ----
  document.querySelectorAll('.color-radio').forEach(function(radio) {
    radio.addEventListener('change', function() {
      var labelId = this.dataset.colorLabelId;
      var labelEl = document.getElementById(labelId);
      if (labelEl) labelEl.textContent = this.dataset.colorValue;

      // Update selected state
      this.closest('.color-grid').querySelectorAll('.color-item').forEach(function(item) {
        item.classList.remove('is-selected');
      });
      this.closest('.color-item').classList.add('is-selected');
    });
  });

  // ---- Size button selection ----
  document.querySelectorAll('.size-button').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var sectionEl = this.closest('.size-section');
      var optionPos = parseInt(this.dataset.optionPosition, 10);
      var sizeValue = this.dataset.size;

      // Update active button
      sectionEl.querySelectorAll('.size-button').forEach(function(b) {
        b.classList.remove('active');
      });
      this.classList.add('active');

      // Update hidden select (if theme uses one)
      var selects = document.querySelectorAll('select[name*="option"]');
      selects.forEach(function(sel) {
        // Try to match by position
        var nameNum = parseInt((sel.name || '').replace(/[^0-9]/g, ''), 10);
        if (nameNum === optionPos || selects.length === 1) {
          sel.value = sizeValue;
          sel.dispatchEvent(new Event('change', { bubbles: true }));
        }
      });
    });
  });

  // ---- CEP mask ----
  var cepInput = document.getElementById('shipping-cep-input');
  if (cepInput) {
    cepInput.addEventListener('input', function() {
      var v = this.value.replace(/\D/g, '');
      if (v.length > 5) v = v.slice(0, 5) + '-' + v.slice(5, 8);
      this.value = v;
    });
  }

  // ---- Shipping calculator ----
  var shippingBtn = document.getElementById('shipping-calc-btn');
  var shippingResult = document.getElementById('shipping-result');
  if (shippingBtn) {
    shippingBtn.addEventListener('click', function() {
      var cep = (cepInput ? cepInput.value : '').replace(/\D/g, '');
      if (cep.length === 8) {
        shippingResult.textContent = 'Calculando...';
        fetch('/apps/shipping?zip=' + cep + '&variant=' + document.querySelector('.product-variant-id').value)
          .then(function(r) { return r.json(); })
          .then(function(data) {
            shippingResult.textContent = data.message || 'Frete calculado com sucesso.';
          })
          .catch(function() {
            shippingResult.textContent = 'Não foi possível calcular o frete agora.';
          });
      } else {
        shippingResult.textContent = 'Por favor, insira um CEP válido (ex: 01310-100).';
      }
    });
  }

  // ---- Wishlist button ----
  var wishlistBtn = document.getElementById('wishlist-btn');
  if (wishlistBtn) {
    wishlistBtn.addEventListener('click', function() {
      var icon = this.querySelector('.wishlist-icon');
      var text = this.querySelector('.wishlist-text');
      if (icon.getAttribute('fill') === 'none') {
        icon.setAttribute('fill', '#D42B2B');
        icon.setAttribute('stroke', '#D42B2B');
        text.textContent = 'Adicionado à lista de desejo';
      } else {
        icon.setAttribute('fill', 'none');
        icon.setAttribute('stroke', 'currentColor');
        text.textContent = 'Adicionar a lista de desejo';
      }
    });
  }

  // ---- Floating buy button ----
  var floatingBtn = document.getElementById('floating-buy-btn');
  if (floatingBtn) {
    floatingBtn.addEventListener('click', function() {
      var buyBtn = document.querySelector('.btn-buy');
      if (buyBtn) buyBtn.click();
    });
  }

  // ---- Modality tabs ----
  (function() {
    var tabs = document.querySelectorAll('.pinfo-modality__tab');
    if (!tabs.length) return;
    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        var key = this.dataset.tab;
        tabs.forEach(function(t) {
          t.classList.remove('pinfo-modality__tab--active');
          t.setAttribute('aria-selected', 'false');
        });
        document.querySelectorAll('.pinfo-modality__panel').forEach(function(p) {
          p.classList.remove('pinfo-modality__panel--active');
          p.hidden = true;
        });
        this.classList.add('pinfo-modality__tab--active');
        this.setAttribute('aria-selected', 'true');
        var panel = document.getElementById('tab-' + key);
        if (panel) { panel.classList.add('pinfo-modality__panel--active'); panel.hidden = false; }
      });
    });
  })();
})();
</script>
