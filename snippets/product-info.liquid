{%- assign selected_variant = product.selected_or_first_available_variant -%}

<style>
  /* ====== RESET STYLES ====== */
  .product-info-refactored {
    max-width: 100%;
    background: white;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  .product-info-refactored * {
    box-sizing: border-box;
  }

  /* ====== CONTAINER ====== */
  .product-container {
    max-width: 100%;
    margin: 0 auto;
    background: white;
    display: flex;
    flex-direction: column;
  }

  /* ====== GALLERY ====== */
  .product-gallery {
    width: 100%;
    background: #f5f5f5;
  }

  .gallery-image {
    width: 100%;
    height: 300px;
    object-fit: cover;
    display: block;
  }

  .gallery-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    padding: 12px 0;
    background: white;
  }

  .gallery-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #EEEEEE;
    cursor: pointer;
    border: none;
    transition: background 0.3s;
  }

  .gallery-dot.active {
    background: #D42B2B;
  }

  /* ====== PRODUCT INFO BLOCK ====== */
  .product-info-block {
    padding: 16px;
    flex: 1;
  }

  /* ====== TITLE ====== */
  .product-title {
    font-size: 22px;
    font-weight: 600;
    color: #111111;
    line-height: 1.3;
    margin: 20px 0 8px;
    word-wrap: break-word;
  }

  /* ====== RATINGS ====== */
  .product-ratings {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    margin-bottom: 8px;
  }

  .product-ratings .stars {
    color: #FFCE00;
    display: flex;
    gap: 2px;
  }

  .product-ratings .count {
    color: #0086FF;
    text-decoration: underline;
    cursor: pointer;
  }

  /* ====== SKU ====== */
  .product-sku {
    font-size: 13px;
    color: #888888;
    margin-bottom: 16px;
  }

  /* ====== PRICE SECTION ====== */
  .price-section {
    margin-bottom: 16px;
  }

  .product-price {
    font-size: 32px;
    font-weight: 700;
    color: #111111;
    line-height: 1;
    margin-bottom: 4px;
  }

  .product-installment {
    font-size: 14px;
    color: #555555;
    margin-top: 4px;
  }

  /* ====== COLOR SELECTOR ====== */
  .color-section {
    margin-bottom: 16px;
  }

  .section-label {
    font-size: 14px;
    color: #333333;
    margin-bottom: 10px;
    font-weight: 500;
  }

  .color-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 8px;
    margin-bottom: 8px;
  }

  .color-item {
    position: relative;
    width: 52px;
    height: 52px;
    border-radius: 4px;
    border: 2px solid transparent;
    overflow: hidden;
    cursor: pointer;
    transition: all 0.2s;
  }

  .color-item input {
    display: none;
  }

  .color-item input:checked + .color-thumbnail {
    border-color: #D42B2B;
  }

  .color-thumbnail {
    width: 100%;
    height: 100%;
    border-radius: 4px;
    border: 2px solid transparent;
    transition: border 0.2s;
  }

  /* ====== SIZE SELECTOR ====== */
  .size-section {
    margin-bottom: 16px;
  }

  .size-grid {
    display: grid;
    gap: 8px;
    margin-bottom: 8px;
  }

  .size-grid-row-1 {
    grid-template-columns: repeat(6, 1fr);
  }

  .size-grid-row-2 {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 8px;
  }

  .size-button {
    height: 48px;
    border: 1px solid #CCCCCC;
    border-radius: 4px;
    background: white;
    font-size: 16px;
    font-weight: 500;
    color: #111111;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .size-button:hover {
    border-color: #999999;
  }

  .size-button.active {
    border: 2px solid #D42B2B;
    font-weight: 600;
  }

  .size-button.unavailable {
    color: #CCCCCC;
    cursor: not-allowed;
    background: #FAFAFA;
  }

  /* ====== BUTTON SECTION ====== */
  .button-section {
    display: flex;
    gap: 8px;
    margin-bottom: 16px;
    align-items: center;
  }

  .btn-buy {
    flex: 1;
    height: 52px;
    background: #D42B2B;
    color: white;
    border: none;
    border-radius: 4px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .btn-buy:hover {
    background: #B91F1F;
  }

  .btn-cart {
    width: 52px;
    height: 52px;
    border: 1px solid #CCCCCC;
    border-radius: 4px;
    background: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    font-size: 20px;
  }

  .btn-cart:hover {
    border-color: #999999;
  }

  /* ====== FEATURES SECTION ====== */
  .features-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin: 16px 0;
  }

  .feature-btn {
    height: 44px;
    border: 1px solid #CCCCCC;
    border-radius: 4px;
    background: white;
    font-size: 13px;
    color: #333333;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: all 0.2s;
  }

  .feature-btn:hover {
    border-color: #999999;
  }

  .feature-icon {
    width: 14px;
    height: 14px;
  }

  /* ====== WISHLIST ====== */
  .wishlist-section {
    padding: 12px 0;
    border-bottom: 1px solid #EEEEEE;
    margin-bottom: 16px;
  }

  .wishlist-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 14px;
    color: #333333;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0;
    transition: color 0.2s;
  }

  .wishlist-btn:hover {
    color: #D42B2B;
  }

  .wishlist-icon {
    width: 18px;
    height: 18px;
  }

  /* ====== SHIPPING CALC ====== */
  .shipping-section {
    margin: 16px 0;
  }

  .shipping-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 14px;
    font-weight: 500;
    color: #111111;
    margin-bottom: 10px;
  }

  .shipping-help {
    color: #0086FF;
    cursor: pointer;
    text-decoration: none;
    font-size: 13px;
  }

  .shipping-form {
    display: flex;
    gap: 8px;
  }

  .shipping-input {
    flex: 0 1 55%;
    height: 48px;
    border: 1px solid #CCCCCC;
    border-radius: 4px;
    padding: 0 12px;
    font-size: 14px;
    color: #111111;
  }

  .shipping-input::placeholder {
    color: #CCCCCC;
  }

  .shipping-btn {
    flex: 0 1 43%;
    height: 48px;
    background: #D42B2B;
    color: white;
    border: none;
    border-radius: 4px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
  }

  .shipping-btn:hover {
    background: #B91F1F;
  }

  /* ====== ACCORDION ====== */
  .accordion-section {
    border-top: 1px solid #EEEEEE;
    margin-top: 16px;
  }

  .accordion-item {
    border-bottom: 1px solid #EEEEEE;
  }

  .accordion-header {
    height: 56px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: white;
    border: none;
    cursor: pointer;
    padding: 0;
    width: 100%;
    font-size: 15px;
    font-weight: 500;
    color: #111111;
    transition: all 0.2s;
  }

  .accordion-header:hover {
    background: #FAFAFA;
  }

  .accordion-toggle {
    width: 18px;
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #D42B2B;
    font-size: 20px;
  }

  .accordion-content {
    display: none;
    padding: 16px 0;
    color: #555555;
    font-size: 14px;
    line-height: 1.6;
  }

  .accordion-content.open {
    display: block;
  }

  /* ====== FLOATING BUTTON ====== */
  .floating-buy-btn {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 52px;
    background: #D42B2B;
    color: white;
    border: none;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    z-index: 1000;
    width: 100%;
  }

  .floating-buy-btn.visible {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ====== RESPONSIVE ====== */
  @media (max-width: 640px) {
    .product-info-block {
      padding: 16px;
    }

    .product-title {
      font-size: 18px;
      margin: 16px 0 8px;
    }

    .product-price {
      font-size: 28px;
    }

    .color-grid {
      grid-template-columns: repeat(4, 1fr);
    }

    .size-grid-row-1,
    .size-grid-row-2 {
      grid-template-columns: repeat(3, 1fr);
    }

    .features-section {
      grid-template-columns: 1fr;
    }

    .shipping-form {
      flex-direction: column;
    }

    .shipping-input,
    .shipping-btn {
      flex: 1;
      width: 100%;
    }
  }
</style>

<div class="product-info-refactored">
  <div class="product-container">
    <!-- GALLERY (rendered separately in product-template) -->

    <!-- PRODUCT INFO BLOCK -->
    <div class="product-info-block">
      
      <!-- TITLE -->
      <h1 class="product-title">{{ product.title }}</h1>

      <!-- RATINGS -->
      <div class="product-ratings">
        <span class="stars">
          <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
        </span>
        <span class="count" data-review-count>1.248</span>
      </div>

      <!-- SKU -->
      <div class="product-sku">SKU: {{ selected_variant.sku | default: product.id }}</div>

      <!-- PRICE -->
      <div class="price-section">
        <div class="product-price">{{ selected_variant.price | money_without_trailing_zeros }}</div>
        {%- if selected_variant.compare_at_price > selected_variant.price -%}
          <div class="product-installment">
            {%- assign monthly = selected_variant.price | divided_by: 12 | money_without_trailing_zeros -%}
            ou 12x de {{ monthly }}
          </div>
        {%- endif -%}
      </div>

      <!-- COLOR SELECTOR -->
      {%- form 'product', product, class: 'product-form' -%}
      {%- unless product.has_only_default_variant -%}
        {%- for option in product.options_with_values -%}
          {%- if option.name == 'Cor' or option.name == 'cor' or option.name == 'Color' or option.name == 'color' -%}
            <div class="color-section">
              <label class="section-label">Cor: <span id="selected-color">{{ option.selected_value }}</span></label>
              <div class="color-grid">
                {%- for value in option.values -%}
                  <div class="color-item">
                    <input 
                      type="radio" 
                      name="option-{{ forloop.index0 }}" 
                      value="{{ value }}"
                      {% if value == option.selected_value %}checked{% endif %}
                      onchange="document.getElementById('selected-color').textContent = this.value"
                    >
                    <img class="color-thumbnail" src="{{ product.featured_image.src | img_url: '52x' }}" alt="{{ value }}">
                  </div>
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- endunless -%}

      <!-- SIZE SELECTOR -->
      {%- unless product.has_only_default_variant -%}
        {%- for option in product.options_with_values -%}
          {%- if option.name == 'Tamanho' or option.name == 'tamanho' or option.name == 'Size' or option.name == 'size' -%}
            <div class="size-section">
              <label class="section-label">Selecione o tamanho</label>
              <div style="display: grid; gap: 8px;">
                <!-- Row 1: 6 sizes -->
                <div class="size-grid size-grid-row-1">
                  {%- for value in option.values | slice: 0, 6 -%}
                    <button 
                      type="button" 
                      class="size-button {% if value == option.selected_value %}active{% endif %}"
                      onclick="this.parentElement.querySelectorAll('.size-button').forEach(b => b.classList.remove('active')); this.classList.add('active'); document.querySelector('select[name*=option]').value = '{{ value }}'; document.querySelector('select[name*=option]').dispatchEvent(new Event('change'));"
                    >
                      {{ value }}
                    </button>
                  {%- endfor -%}
                </div>
                
                <!-- Row 2: Remaining sizes -->
                {%- if option.values.size > 6 -%}
                  <div class="size-grid size-grid-row-2">
                    {%- for value in option.values | slice: 6, 10 -%}
                      <button 
                        type="button" 
                        class="size-button {% if value == option.selected_value %}active{% endif %}"
                        onclick="this.parentElement.querySelectorAll('.size-button').forEach(b => b.classList.remove('active')); this.classList.add('active'); document.querySelector('select[name*=option]').value = '{{ value }}'; document.querySelector('select[name*=option]').dispatchEvent(new Event('change'));"
                      >
                        {{ value }}
                      </button>
                    {%- endfor -%}
                  </div>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- endunless -%}

      <!-- BUY BUTTONS -->
      <div class="button-section">
        <button type="submit" class="btn-buy" data-action="add-to-cart">Comprar Agora</button>
        <button type="button" class="btn-cart" title="Adicionar ao carrinho">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="9" cy="21" r="1"></circle>
            <circle cx="20" cy="21" r="1"></circle>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
          </svg>
        </button>
      </div>

      <!-- FEATURES -->
      <div class="features-section">
        <button type="button" class="feature-btn">
          <svg class="feature-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"></path>
          </svg>
          Provador Virtual
        </button>
        <button type="button" class="feature-btn">
          <svg class="feature-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
          </svg>
          Tabela de Medidas
        </button>
      </div>

      <!-- WISHLIST -->
      <div class="wishlist-section">
        <button type="button" class="wishlist-btn">
          <svg class="wishlist-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
          </svg>
          Adicionar a lista de desejo
        </button>
      </div>

      <!-- SHIPPING CALCULATOR -->
      <div class="shipping-section">
        <div class="shipping-header">
          <span>Entregar para:</span>
          <a href="#" class="shipping-help">Não sei meu CEP</a>
        </div>
        <div class="shipping-form">
          <input type="text" class="shipping-input" placeholder="00000-000" maxlength="9">
          <button type="button" class="shipping-btn">Calcular Frete</button>
        </div>
      </div>

      <!-- ACCORDIONS -->
      <div class="accordion-section">
        <div class="accordion-item">
          <button type="button" class="accordion-header" onclick="this.nextElementSibling.classList.toggle('open'); this.querySelector('.accordion-toggle').textContent = this.nextElementSibling.classList.contains('open') ? '−' : '+'; ">
            <span>Descrição do Produto</span>
            <span class="accordion-toggle">+</span>
          </button>
          <div class="accordion-content">
            {{ product.description | strip_html | truncatewords: 50 }}
          </div>
        </div>

        <div class="accordion-item">
          <button type="button" class="accordion-header" onclick="this.nextElementSibling.classList.toggle('open'); this.querySelector('.accordion-toggle').textContent = this.nextElementSibling.classList.contains('open') ? '−' : '+'; ">
            <span>Especificações Técnicas</span>
            <span class="accordion-toggle">+</span>
          </button>
          <div class="accordion-content">
            <strong>Marca:</strong> {{ product.vendor }}<br>
            <strong>SKU:</strong> {{ selected_variant.sku | default: product.id }}<br>
            {%- if selected_variant.weight -%}
              <strong>Peso:</strong> {{ selected_variant.weight }} {{ shop.weight_unit }}<br>
            {%- endif -%}
            <strong>Disponibilidade:</strong> {% if selected_variant.available %}Em estoque{% else %}Esgotado{% endif %}
          </div>
        </div>
      </div>

      {%- endform -%}
    </div>
  </div>
</div>

<!-- FLOATING BUY BUTTON (Mobile) -->
<button class="floating-buy-btn visible" onclick="document.querySelector('.btn-buy').click();">Comprar Agora</button>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Show floating button on mobile
  if (window.innerWidth < 641) {
    document.querySelector('.floating-buy-btn').classList.add('visible');
  }

  // Color selector functionality
  const colorInputs = document.querySelectorAll('input[name^="option"]');
  colorInputs.forEach(input => {
    input.addEventListener('change', function() {
      document.getElementById('selected-color').textContent = this.value;
    });
  });

  // Wishlist button
  document.querySelector('.wishlist-btn').addEventListener('click', function(e) {
    e.preventDefault();
    this.style.color = '#D42B2B';
    this.querySelector('.wishlist-icon').style.fill = 'currentColor';
  });

  // Shipping calculator
  document.querySelector('.shipping-btn').addEventListener('click', function() {
    const cep = document.querySelector('.shipping-input').value;
    if (cep.length === 9) {
      alert('Frete calculado para CEP: ' + cep);
    } else {
      alert('Por favor, insira um CEP válido');
    }
  });
});
</script>
