# Olist / Tiny ERP — API v3 (OAuth 2.0)
# Gere em: https://erp.tiny.com.br → Configurações → API → Criar aplicação
TINY_CLIENT_ID=
TINY_CLIENT_SECRET=
TINY_REDIRECT_URI=http://localhost:3000/oauth/callback
# Tokens preenchidos automaticamente pelo `npm run auth`
TINY_ACCESS_TOKEN=
TINY_REFRESH_TOKEN=
TINY_TOKEN_EXPIRES_AT=

# Shopify Admin API
# Gere em: Shopify Admin → Configurações → Apps → Desenvolver apps → Criar app
# Escopos: read_products, write_products
SHOPIFY_STORE_DOMAIN=royalatacado.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_

# Configurações
# Nome exato da Lista de Preços no Olist que contém os preços de atacado
OLIST_PRICELIST_NAME=ATACADO
# Metafield no Shopify onde grava o preço (namespace.key)
SHOPIFY_METAFIELD_NAMESPACE=custom
SHOPIFY_METAFIELD_KEY=preco_atacado
# Use 0 (preço promocional) ou 1 (preço normal da lista) — Olist guarda os dois
OLIST_USE_PROMO_PRICE=1
